<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ACM_Manager" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>

    <!-- ============================================================
         1. 메뉴 오픈 시 액션 등록
         - SN Mod Support APIs: md.Interact_Menu_API.Get_Actions
         ============================================================ -->
    <cue name="ACM_Get_Actions" instantiate="true">
      <conditions>
        <event_cue_signalled cue="@md.Interact_Menu_API.Get_Actions" />
        <check_value value="@event.param.$object.isclass.ship" />
        <check_value value="@event.param.$object.isplayerowned" />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 (우클릭 대상 + 다중 선택된 다른 함선들) -->
        <create_list name="$Ships" />
        <append_to_list name="$Ships" exact="event.param.$object" />
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <!-- 선택 함선 수에 따라 노출 섹션 결정 -->
        <set_value name="$section" exact="if $Ships.count gt 1 then 'selected_orders_all' else 'selected_orders'" />

        <!-- 1. 함장 자동 할당 (id="2") -->
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'acm_assign_pilot',
            $section  = $section,
            $text     = readtext.{98765}.{2},
            $mouseover = readtext.{98765}.{20},
            $callback = ACM_Assign_Callback,
            ]" />

        <!-- 2. 함장 할당 해제 (id="3") -->
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'acm_unassign_pilot',
            $section  = $section,
            $text     = readtext.{98765}.{3},
            $mouseover = readtext.{98765}.{30},
            $callback = ACM_Unassign_Callback,
            ]" />

        <!-- 3. 함장 해고 (id="4") -->
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'acm_fire_pilot',
            $section  = $section,
            $text     = readtext.{98765}.{4},
            $mouseover = readtext.{98765}.{40},
            $callback = ACM_Fire_Callback,
            ]" />

        <!-- [DEBUG] 선원 role 스캔 -->
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'acm_debug_scan',
            $section  = $section,
            $text     = '[DEBUG] 선원 role 스캔',
            $callback = ACM_Debug_Scan_Callback,
            ]" />
      </actions>
    </cue>


    <!-- ============================================================
         2. 함장 일괄 할당 해제 콜백
         - 함장 슬롯만 비움(NPC는 함선에 일반 승무원으로 잔류)
         ============================================================ -->
    <cue name="ACM_Unassign_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[ACM] Unassign start: ' + $Ships.count + ' ships'" filter="general" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            <set_value name="$Template" exact="@$Pilot.npctemplate" />
            <set_value name="$PilotExists" exact="$Pilot.exists" />
            
            <debug_text text="'[ACM] Unassigning pilot for: ' + $Ship.knownname + ' | pilot_name=' + $Pilot.knownname + ' | pilot_exists=' + $PilotExists + ' | template=' + $Template" filter="general" />
            
            <!-- 조종사 보직 해제 -->
            <dismiss_control_entity actor="$Pilot" object="$Ship" />
            
            <!-- NPC 엔티티 역할 변경 (일반 승무원/미배정 상태) -->
            <do_if value="$PilotExists">
              <set_entity_role entity="$Pilot" role="entityrole.unassigned" />
              <set_entity_role_object entity="$Pilot" object="$Ship" />
            </do_if>
            
            <!-- NPC 템플릿 역할 변경 -->
            <do_if value="$Template">
              <do_if value="$Ship.people.{$Template}.exists">
                <set_npc_template_role object="$Ship" template="$Template" role="entityrole.unassigned" />
              </do_if>
              <do_else>
                <create_npc_template object="$Ship" entity="$Pilot" role="entityrole.unassigned" />
              </do_else>
            </do_if>
            <do_else>
              <debug_text text="'[ACM]   - Warning: No npctemplate found for pilot!'" filter="general" />
            </do_else>
            
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{21}.[$Ship.knownname]" post="true" />
          </do_if>
          <do_else>
            <debug_text text="'[ACM] Unassign skip (no pilot): ' + $Ship.knownname" filter="general" />
          </do_else>
        </do_all>
      </actions>
    </cue>


    <!-- ============================================================
         3. 함장 일괄 해고 콜백
         - 함장 슬롯 비우고 NPC 제거
         ============================================================ -->
    <cue name="ACM_Fire_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[ACM] Fire: ' + $Ships.count + ' ships'" filter="general" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            <set_value name="$PilotName" exact="$Pilot.knownname" />
            <debug_text text="'[ACM] Firing: ' + $PilotName + ' from ' + $Ship.knownname" filter="general" />
            
            <!-- 조종사 보직 해제 후 제거 (꼬임 방지) -->
            <dismiss_control_entity actor="$Pilot" object="$Ship" />
            <destroy_object object="$Pilot" />
            
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{22}.[$Ship.knownname, $PilotName]" post="true" />
          </do_if>
          <do_else>
            <debug_text text="'[ACM] Fire skip (no pilot): ' + $Ship.knownname" filter="general" />
          </do_else>
        </do_all>
      </actions>
    </cue>


    <!-- ============================================================
         4. 함장 일괄 배정 콜백
         - 은하 내 플레이어 함선에서 미배정 선원 중 조종술 최고치 탐색
         - 16등급 우선순위 정렬 (XL>L>M>S 및 fight>trade>mine>build)
         ============================================================ -->
    <cue name="ACM_Assign_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[ACM] Assign: ' + $Ships.count + ' ships'" filter="general" />

        <!-- 1순위: 클래스(XL>L>M>S), 2순위: 카테고리(전함>민간함) 우선순위로 정렬하기 위해 분할 리스트 생성 -->
        <create_list name="$Ships_XL" />
        <create_list name="$Ships_L" />
        <create_list name="$Ships_M" />
        <create_list name="$Ships_S" />

        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="not @$Ship.pilot">
            <do_if value="$Ship.isclass.ship_xl">
              <append_to_list name="$Ships_XL" exact="$Ship" />
            </do_if>
            <do_elseif value="$Ship.isclass.ship_l">
              <append_to_list name="$Ships_L" exact="$Ship" />
            </do_elseif>
            <do_elseif value="$Ship.isclass.ship_m">
              <append_to_list name="$Ships_M" exact="$Ship" />
            </do_elseif>
            <do_elseif value="$Ship.isclass.ship_s">
              <append_to_list name="$Ships_S" exact="$Ship" />
            </do_elseif>
          </do_if>
        </do_all>

        <create_list name="$SortedShips" />

        <!-- 용도 우선순위 목록 정의 (fight > trade > mine > build) -->
        <create_list name="$Purposes" />
        <append_to_list name="$Purposes" exact="purpose.fight" />
        <append_to_list name="$Purposes" exact="purpose.trade" />
        <append_to_list name="$Purposes" exact="purpose.mine" />
        <append_to_list name="$Purposes" exact="purpose.build" />

        <!-- 정렬 루프용 클래스 리스트 모음 -->
        <create_list name="$ClassLists" />
        <append_to_list name="$ClassLists" exact="$Ships_XL" />
        <append_to_list name="$ClassLists" exact="$Ships_L" />
        <append_to_list name="$ClassLists" exact="$Ships_M" />
        <append_to_list name="$ClassLists" exact="$Ships_S" />

        <!-- 클래스별(XL -> L -> M -> S) 순회하며 세부 용도 정렬 수행 -->
        <do_all exact="$ClassLists.count" counter="$c">
          <set_value name="$CurrentClassList" exact="$ClassLists.{$c}" />

          <!-- 1단계: 정의된 용도 순서대로 병합 -->
          <do_all exact="$Purposes.count" counter="$p">
            <set_value name="$CurrentPurpose" exact="$Purposes.{$p}" />
            <do_all exact="$CurrentClassList.count" counter="$i">
              <set_value name="$Ship" exact="$CurrentClassList.{$i}" />
              <do_if value="$Ship.primarypurpose == $CurrentPurpose">
                <append_to_list name="$SortedShips" exact="$Ship" />
              </do_if>
            </do_all>
          </do_all>

          <!-- 2단계: 그 외(기타) 용도 함선들 추가 -->
          <do_all exact="$CurrentClassList.count" counter="$i">
            <set_value name="$Ship" exact="$CurrentClassList.{$i}" />
            <do_if value="not $Purposes.indexof.{$Ship.primarypurpose}">
              <append_to_list name="$SortedShips" exact="$Ship" />
            </do_if>
          </do_all>
        </do_all>

        <!-- 플레이어 소유 전 함선 목록 (후보 탐색용, 격납된 함선도 찾기 위해 recursive="true" 필수) -->
        <find_ship name="$PlayerShips" owner="faction.player" multiple="true" space="player.galaxy" recursive="true" />

        <!-- 중복 배정 방지 리스트 -->
        <create_list name="$AssignedCandidates" />
        <create_list name="$AssignedSeeds" />

        <!-- 이제 정렬된 함선 리스트를 순회하며 배정 진행 -->
        <do_all exact="$SortedShips.count" counter="$i">
          <set_value name="$Ship" exact="$SortedShips.{$i}" />

          <debug_text text="'[ACM] Processing empty pilot seat for ship: ' + $Ship.knownname + ' (class=' + $Ship.class + ' purpose=' + $Ship.primarypurpose + ')'" filter="general" />
          <set_value name="$BestCandidate" exact="null" />
          <set_value name="$BestPiloting" value="-1" />
          <set_value name="$BestSource" exact="null" />
          <set_value name="$BestSeed" exact="0" />

          <!-- 1단계: 자기 자신 함선 내부에서 최고의 미배정 선원 템플릿 탐색 -->
          <set_value name="$LocalPeople" exact="$Ship.people.list" />
          <do_all exact="$LocalPeople.count" counter="$k">
            <set_value name="$Template" exact="$LocalPeople.{$k}" />
            <set_value name="$Role" exact="$Ship.people.{$Template}.role" />
            <set_value name="$Seed" exact="@$Ship.people.{$Template}.seed" />
            <set_value name="$NPC_Piloting" exact="$Ship.people.{$Template}.skill.{skilltype.piloting}" />
            <set_value name="$IsAlreadyAssigned" exact="$AssignedCandidates.indexof.{$Template} or ($Seed gt 0 and $AssignedSeeds.indexof.{$Seed})" />
            
            <!-- 템플릿의 롤이 미배정이고, 이번 일괄 배정에서 아직 선발되지 않은 선원만 -->
            <do_if value="$Role == entityrole.unassigned and not $IsAlreadyAssigned">
              <do_if value="$NPC_Piloting gt $BestPiloting">
                <set_value name="$BestPiloting" exact="$NPC_Piloting" />
                <set_value name="$BestCandidate" exact="$Template" />
                <set_value name="$BestSource" exact="$Ship" />
                <set_value name="$BestSeed" exact="$Seed" />
              </do_if>
            </do_if>
          </do_all>

          <!-- 2단계: 자기 배에서 찾지 못한 경우에만 타 함선들을 조회하여 템플릿 탐색 -->
          <do_if value="not $BestCandidate">
            <do_all exact="$PlayerShips.count" counter="$j">
              <set_value name="$PShip" exact="$PlayerShips.{$j}" />
              <do_if value="$PShip != $Ship">
                <set_value name="$RemotePeople" exact="$PShip.people.list" />
                <do_all exact="$RemotePeople.count" counter="$k">
                  <set_value name="$Template" exact="$RemotePeople.{$k}" />
                  <set_value name="$Role" exact="$PShip.people.{$Template}.role" />
                  <set_value name="$Seed" exact="@$PShip.people.{$Template}.seed" />
                  <set_value name="$NPC_Piloting" exact="$PShip.people.{$Template}.skill.{skilltype.piloting}" />
                  <set_value name="$IsAlreadyAssigned" exact="$AssignedCandidates.indexof.{$Template} or ($Seed gt 0 and $AssignedSeeds.indexof.{$Seed})" />
                  
                  <do_if value="$Role == entityrole.unassigned and not $IsAlreadyAssigned">
                    <do_if value="$NPC_Piloting gt $BestPiloting">
                      <set_value name="$BestPiloting" exact="$NPC_Piloting" />
                      <set_value name="$BestCandidate" exact="$Template" />
                      <set_value name="$BestSource" exact="$PShip" />
                      <set_value name="$BestSeed" exact="$Seed" />
                    </do_if>
                  </do_if>
                </do_all>
              </do_if>
            </do_all>
          </do_if>

          <!-- 후보 발견 시 배정 -->
          <do_if value="$BestCandidate">
            <!-- 템플릿이 이미 인스턴스로 존재하는가? -->
            <set_value name="$TargetActor" exact="$BestSource.roleentity.{$BestCandidate}" />
            
            <do_if value="not $TargetActor.exists">
              <!-- 인스턴스가 없으므로 템플릿으로부터 NPC 인스턴스 생성 -->
              <create_npc_from_template name="$TargetActor" object="$BestSource" template="$BestCandidate" owner="faction.player" placementobject="$Ship" required="true" />
            </do_if>

            <do_if value="$TargetActor.exists">
              <debug_text text="'[ACM] Assigning ' + $TargetActor.knownname + ' (skill ' + $BestPiloting + ') to ' + $Ship.knownname" filter="general" />
              <assign_control_entity actor="$TargetActor" object="$Ship" role="controlrole.pilot" post="controlpost.aipilot" transfer="true" init="true" />
              
              <!-- 중복 배정 방지를 위해 선발된 템플릿과 시드 등록 -->
              <append_to_list name="$AssignedCandidates" exact="$BestCandidate" />
              <do_if value="$BestSeed gt 0">
                <append_to_list name="$AssignedSeeds" exact="$BestSeed" />
              </do_if>

              <!-- 이적이 완료되었으므로 소스 배에서 템플릿 제거 -->
              <do_if value="$BestSource.people.{$BestCandidate}.exists">
                <remove_npc_template object="$BestSource" template="$BestCandidate" />
              </do_if>

              <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{23}.[$Ship.knownname, ($BestPiloting / 3), $TargetActor.knownname]" post="true" />
            </do_if>
            <do_else>
              <debug_text text="'[ACM] Failed to instantiate candidate: ' + $BestCandidate + ' for ' + $Ship.knownname" filter="general" />
            </do_else>
          </do_if>
          <do_else>
            <debug_text text="'[ACM] No eligible crew found for: ' + $Ship.knownname" filter="general" />
          </do_else>
        </do_all>
      </actions>
    </cue>


    <!-- ============================================================
         5. [DEBUG] 선원 role 스캔 콜백
         - 실제 controlpost 값 확인용 (미배정인원 role 식별)
         ============================================================ -->
    <cue name="ACM_Debug_Scan_Callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <debug_text text="'[ACM SCAN] ===== ' + $Ship.knownname + ' | people: ' + @$Ship.people.count + '/' + @$Ship.people.capacity" filter="general" />
          <find_object_component name="$ScanList" object="$Ship" class="class.npc" multiple="true" />
          <debug_text text="'[ACM SCAN] Total NPC: ' + $ScanList.count" filter="general" />
          <do_all exact="$ScanList.count" counter="$si">
            <set_value name="$SNPC" exact="$ScanList.{$si}" />
            <debug_text text="'[ACM SCAN] NPC[' + $si + '] name=' + $SNPC.knownname + ' | controlled=' + @$SNPC.controlled + ' | controlpost=' + @$SNPC.controlpost + ' | is_pilot=' + ($Ship.pilot == $SNPC)" filter="general" />
          </do_all>
          <debug_text text="'[ACM SCAN] $Ship.pilot = ' + @$Ship.pilot.knownname" filter="general" />
        </do_all>
      </actions>
    </cue>

  </cues>
</mdscript>
