<?xml version="1.0" encoding="utf-8"?>
<mdscript name="scm" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>

    <!-- ============================================================
         1. 메뉴 오픈 시 액션 등록
         - SN Mod Support APIs: md.Interact_Menu_API.Get_Actions
         ============================================================ -->
    <cue name="scm_get_actions" instantiate="true">
      <conditions>
        <event_cue_signalled cue="@md.Interact_Menu_API.Get_Actions" />
        <check_value value="@event.param.$object.isclass.ship" />
        <check_value value="@event.param.$object.isplayerowned" />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 (우클릭 대상 + 다중 선택된 다른 함선들) -->
        <create_list name="$Ships" />
        <append_to_list name="$Ships" exact="event.param.$object" />
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <!-- 선택 함선 수에 따라 노출 섹션 결정 -->
        <set_value name="$section" exact="if $Ships.count gt 1 then 'selected_orders_all' else 'interaction'" />

        <!-- 단일 함선 선택 시 함장 존재 판별 -->
        <set_value name="$ShipsCount" exact="$Ships.count" />
        <set_value name="$SingleShipHasPilot" exact="false" />
        <do_if value="$ShipsCount == 1">
          <do_if value="@$Ships.{1}.pilot">
            <set_value name="$SingleShipHasPilot" exact="true" />
          </do_if>
        </do_if>

        <!-- 1. 함장 자동 할당 (id="2") -->
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'scm_assign_pilot',
            $section  = $section,
            $text     = readtext.{98765}.{2},
            $mouseover = readtext.{98765}.{20},
            $callback = scm_assign_callback,
            ]" />

        <!-- 2. 함장 할당 해제 (id="3") -->
        <set_value name="$UnassignActive" exact="true" />
        <set_value name="$UnassignMouseover" exact="readtext.{98765}.{30}" />
        <do_if value="$ShipsCount == 1 and not $SingleShipHasPilot">
          <set_value name="$UnassignActive" exact="false" />
          <set_value name="$UnassignMouseover" exact="readtext.{98765}.{31}" />
        </do_if>
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'scm_unassign_pilot',
            $section  = $section,
            $text     = readtext.{98765}.{3},
            $mouseover = $UnassignMouseover,
            $active   = $UnassignActive,
            $callback = scm_unassign_callback,
            ]" />

        <!-- 3. 함장 해고 (id="4") -->
        <set_value name="$FireActive" exact="true" />
        <set_value name="$FireMouseover" exact="readtext.{98765}.{40}" />
        <do_if value="$ShipsCount == 1 and not $SingleShipHasPilot">
          <set_value name="$FireActive" exact="false" />
          <set_value name="$FireMouseover" exact="readtext.{98765}.{41}" />
        </do_if>
        <signal_cue_instantly
          cue="md.Interact_Menu_API.Add_Action"
          param="table[
            $id       = 'scm_fire_pilot',
            $section  = $section,
            $text     = readtext.{98765}.{4},
            $mouseover = $FireMouseover,
             $active   = $FireActive,
             $callback = scm_fire_callback,
             ]" />
 
         <!-- 4. 미배정 인원 채우기 (id="5") -->
         <do_if value="$ShipsCount == 1">
           <set_value name="$FillActive" exact="true" />
           <set_value name="$FillMouseover" exact="readtext.{98765}.{50}" />
           <do_if value="$Ships.{1}.people.free le 0">
             <set_value name="$FillActive" exact="false" />
           </do_if>
           <signal_cue_instantly
             cue="md.Interact_Menu_API.Add_Action"
             param="table[
               $id       = 'scm_fill_unassigned',
               $section  = $section,
               $text     = readtext.{98765}.{6},
               $mouseover = $FillMouseover,
               $active   = $FillActive,
               $callback = scm_fill_unassigned_callback,
               ]" />
         </do_if>
 
         <!-- 5. 세미나 일괄 사용 (id="6") -->
         <set_value name="$SeminarActive" exact="false" />
         <do_all exact="$Ships.count" counter="$i">
           <do_if value="@$Ships.{$i}.pilot">
             <set_value name="$SeminarActive" exact="true" />
           </do_if>
         </do_all>
         <signal_cue_instantly
           cue="md.Interact_Menu_API.Add_Action"
           param="table[
             $id       = 'scm_use_seminar',
             $section  = $section,
             $text     = readtext.{98765}.{7},
             $mouseover = readtext.{98765}.{51},
             $active   = $SeminarActive,
             $callback = scm_use_seminar_callback,
             ]" />
 
       </actions>
     </cue>


    <!-- ============================================================
         2. 함장 일괄 보직 해제 콜백
         - 함장 슬롯만 비움(NPC는 함선에 미배정 인원으로 잔류)
         ============================================================ -->
    <cue name="scm_unassign_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Unassign start: ' + $Ships.count + ' ships'" filter="general" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            
            <!-- 정원 가득 참 방지: 여유 슬롯이 없으면 최하위 선원 1명 자동 해고 -->
            <do_if value="$Ship.people.free le 0">
              <set_value name="$WorstCrew" exact="null" />
              <set_value name="$WorstSkill" exact="9999" />
              <set_value name="$CrewList" exact="$Ship.people.list" />
              <do_all exact="$CrewList.count" counter="$k">
                <set_value name="$Template" exact="$CrewList.{$k}" />
                <set_value name="$Role" exact="$Ship.people.{$Template}.role" />
                <do_if value="$Role != entityrole.pilot and $Template != @$Pilot.npctemplate">
                  <set_value name="$Morale" exact="$Ship.people.{$Template}.skill.morale" />
                  <set_value name="$PrimarySkill" exact="0" />
                  
                  <!-- 역할군에 따른 1차 스킬 식별 (서비스:공학, 해병:나포) -->
                  <do_if value="$Role == entityrole.service">
                    <set_value name="$PrimarySkill" exact="$Ship.people.{$Template}.skill.engineering" />
                  </do_if>
                  <do_elseif value="$Role == entityrole.marine">
                    <set_value name="$PrimarySkill" exact="$Ship.people.{$Template}.skill.boarding" />
                  </do_elseif>
                  <do_else>
                    <!-- 미배정이거나 기타 역할군인 경우, 가장 뛰어난 주력 스킬을 1차 스킬로 가정 -->
                    <set_value name="$MaxBase" exact="0" />
                    <set_value name="$MaxBase" exact="[
                      $Ship.people.{$Template}.skill.piloting,
                      $Ship.people.{$Template}.skill.engineering,
                      $Ship.people.{$Template}.skill.boarding,
                      $Ship.people.{$Template}.skill.management
                    ].max" />
                    <set_value name="$PrimarySkill" exact="$MaxBase" />
                  </do_else>
                  
                  <!-- 바닐라 종합 숙련도 공식: (1차스킬 * 3 + 사기) / 4 -->
                  <set_value name="$EffectiveSkillVal" exact="($PrimarySkill * 3) + $Morale" />
                  
                  <do_if value="$EffectiveSkillVal lt $WorstSkill">
                    <set_value name="$WorstSkill" exact="$EffectiveSkillVal" />
                    <set_value name="$WorstCrew" exact="$Template" />
                  </do_if>
                </do_if>
              </do_all>
              <do_if value="$WorstCrew">
                <debug_text text="'[SCM] Ship full. Firing worst crew ' + $WorstCrew + ' (score: ' + $WorstSkill + ') to make space for dismissed pilot.'" filter="general" />
                <remove_npc_template object="$Ship" template="$WorstCrew" />
              </do_if>
            </do_if>

            <set_value name="$Template" exact="@$Pilot.npctemplate" />
            <set_value name="$PilotExists" exact="$Pilot.exists" />
            
            <debug_text text="'[SCM] Unassigning pilot for: ' + $Ship.knownname + ' | pilot_name=' + $Pilot.knownname + ' | pilot_exists=' + $PilotExists + ' | template=' + $Template" filter="general" />
            
            <!-- 조종사 보직 해제 -->
            <dismiss_control_entity actor="$Pilot" object="$Ship" />
            
            <!-- NPC 엔티티 역할 변경 (미배정 인원 상태) -->
            <do_if value="$PilotExists">
              <set_entity_role entity="$Pilot" role="entityrole.unassigned" />
              <set_entity_role_object entity="$Pilot" object="$Ship" />
            </do_if>
            
            <!-- NPC 템플릿 역할 변경 -->
            <do_if value="$Template">
              <do_if value="$Ship.people.{$Template}.exists">
                <set_npc_template_role object="$Ship" template="$Template" role="entityrole.unassigned" />
              </do_if>
              <do_else>
                <create_npc_template object="$Ship" entity="$Pilot" role="entityrole.unassigned" />
              </do_else>
            </do_if>
            <do_else>
              <debug_text text="'[SCM] Warning: No npctemplate found for pilot!'" filter="general" />
            </do_else>
            
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{21}.[$Ship.knownname]" post="true" />
          </do_if>
        </do_all>
      </actions>
    </cue>


    <!-- ============================================================
         3. 함장 일괄 해고 콜백
         - 함장 슬롯 비우고 NPC 제거
         ============================================================ -->
    <cue name="scm_fire_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Fire: ' + $Ships.count + ' ships'" filter="general" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            <set_value name="$PilotName" exact="$Pilot.knownname" />
            <debug_text text="'[SCM] Firing: ' + $PilotName + ' from ' + $Ship.knownname" filter="general" />
            
            <!-- 조종사 보직 해제 후 제거 (꼬임 방지) -->
            <dismiss_control_entity actor="$Pilot" object="$Ship" />
            <destroy_object object="$Pilot" />
            
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{22}.[$Ship.knownname, $PilotName]" post="true" />
          </do_if>
        </do_all>
      </actions>
    </cue>


    <!-- ============================================================
         4. 함장 일괄 배정 콜백
         - 은하 내 플레이어 함선에서 미배정 선원 중 조종술 최고치 탐색
         - 16등급 우선순위 정렬 (XL>L>M>S 및 fight>trade>mine>build)
         ============================================================ -->
    <cue name="scm_assign_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Assign: ' + $Ships.count + ' ships'" filter="general" />

        <!-- 1순위: 클래스(XL>L>M>S), 2순위: 카테고리(전함>민간함) 우선순위로 정렬하기 위해 분할 리스트 생성 -->
        <create_list name="$Ships_XL" />
        <create_list name="$Ships_L" />
        <create_list name="$Ships_M" />
        <create_list name="$Ships_S" />

        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="not @$Ship.pilot">
            <do_if value="$Ship.isclass.ship_xl">
              <append_to_list name="$Ships_XL" exact="$Ship" />
            </do_if>
            <do_elseif value="$Ship.isclass.ship_l">
              <append_to_list name="$Ships_L" exact="$Ship" />
            </do_elseif>
            <do_elseif value="$Ship.isclass.ship_m">
              <append_to_list name="$Ships_M" exact="$Ship" />
            </do_elseif>
            <do_elseif value="$Ship.isclass.ship_s">
              <append_to_list name="$Ships_S" exact="$Ship" />
            </do_elseif>
          </do_if>
        </do_all>

        <create_list name="$SortedShips" />

        <!-- 용도 우선순위 목록 정의 (fight > trade > mine > build) -->
        <create_list name="$Purposes" />
        <append_to_list name="$Purposes" exact="purpose.fight" />
        <append_to_list name="$Purposes" exact="purpose.trade" />
        <append_to_list name="$Purposes" exact="purpose.mine" />
        <append_to_list name="$Purposes" exact="purpose.build" />

        <!-- 정렬 루프용 클래스 리스트 모음 -->
        <create_list name="$ClassLists" />
        <append_to_list name="$ClassLists" exact="$Ships_XL" />
        <append_to_list name="$ClassLists" exact="$Ships_L" />
        <append_to_list name="$ClassLists" exact="$Ships_M" />
        <append_to_list name="$ClassLists" exact="$Ships_S" />

        <!-- 클래스별(XL -> L -> M -> S) 순회하며 세부 용도 정렬 수행 -->
        <do_all exact="$ClassLists.count" counter="$c">
          <set_value name="$CurrentClassList" exact="$ClassLists.{$c}" />

          <!-- 1단계: 정의된 용도 순서대로 병합 -->
          <do_all exact="$Purposes.count" counter="$p">
            <set_value name="$CurrentPurpose" exact="$Purposes.{$p}" />
            <do_all exact="$CurrentClassList.count" counter="$i">
              <set_value name="$Ship" exact="$CurrentClassList.{$i}" />
              <do_if value="$Ship.primarypurpose == $CurrentPurpose">
                <append_to_list name="$SortedShips" exact="$Ship" />
              </do_if>
            </do_all>
          </do_all>

          <!-- 2단계: 그 외(기타) 용도 함선들 추가 -->
          <do_all exact="$CurrentClassList.count" counter="$i">
            <set_value name="$Ship" exact="$CurrentClassList.{$i}" />
            <do_if value="not $Purposes.indexof.{$Ship.primarypurpose}">
              <append_to_list name="$SortedShips" exact="$Ship" />
            </do_if>
          </do_all>
        </do_all>

        <!-- 플레이어 소유 전 함선 목록 (후보 탐색용, 격납된 함선도 찾기 위해 recursive="true" 필수) -->
        <find_ship name="$PlayerShips" owner="faction.player" multiple="true" space="player.galaxy" recursive="true" />

        <!-- 중복 배정 방지 리스트 -->
        <create_list name="$AssignedCandidates" />
        <create_list name="$AssignedSeeds" />

        <!-- 이제 정렬된 함선 리스트를 순회하며 배정 진행 -->
        <do_all exact="$SortedShips.count" counter="$i">
          <set_value name="$Ship" exact="$SortedShips.{$i}" />

          <set_value name="$BestCandidate" exact="null" />
          <set_value name="$BestPiloting" value="-1" />
          <set_value name="$BestSource" exact="null" />
          <set_value name="$BestSeed" exact="0" />

          <!-- 1단계: 자기 자신 함선 내부에서 최고의 미배정 선원 템플릿 탐색 -->
          <set_value name="$LocalPeople" exact="$Ship.people.list" />
          <do_all exact="$LocalPeople.count" counter="$k">
            <set_value name="$Template" exact="$LocalPeople.{$k}" />
            <set_value name="$Role" exact="$Ship.people.{$Template}.role" />
            <set_value name="$Seed" exact="@$Ship.people.{$Template}.seed" />
            <set_value name="$NPC_Piloting" exact="$Ship.people.{$Template}.skill.{skilltype.piloting}" />
            <set_value name="$IsAlreadyAssigned" exact="$AssignedCandidates.indexof.{$Template} or ($Seed gt 0 and $AssignedSeeds.indexof.{$Seed})" />
            
            <!-- 템플릿의 롤이 미배정이고, 이번 일괄 배정에서 아직 선발되지 않은 선원만 -->
            <do_if value="$Role == entityrole.unassigned and not $IsAlreadyAssigned">
              <do_if value="$NPC_Piloting gt $BestPiloting">
                <set_value name="$BestPiloting" exact="$NPC_Piloting" />
                <set_value name="$BestCandidate" exact="$Template" />
                <set_value name="$BestSource" exact="$Ship" />
                <set_value name="$BestSeed" exact="$Seed" />
              </do_if>
            </do_if>
          </do_all>

          <!-- 2단계: 자기 배에서 찾지 못한 경우에만 타 함선들을 조회하여 템플릿 탐색 -->
          <do_if value="not $BestCandidate">
            <do_all exact="$PlayerShips.count" counter="$j">
              <set_value name="$PShip" exact="$PlayerShips.{$j}" />
              <do_if value="$PShip != $Ship">
                <set_value name="$RemotePeople" exact="$PShip.people.list" />
                <do_all exact="$RemotePeople.count" counter="$k">
                  <set_value name="$Template" exact="$RemotePeople.{$k}" />
                  <set_value name="$Role" exact="$PShip.people.{$Template}.role" />
                  <set_value name="$Seed" exact="@$PShip.people.{$Template}.seed" />
                  <set_value name="$NPC_Piloting" exact="$PShip.people.{$Template}.skill.{skilltype.piloting}" />
                  <set_value name="$IsAlreadyAssigned" exact="$AssignedCandidates.indexof.{$Template} or ($Seed gt 0 and $AssignedSeeds.indexof.{$Seed})" />
                  
                  <do_if value="$Role == entityrole.unassigned and not $IsAlreadyAssigned">
                    <do_if value="$NPC_Piloting gt $BestPiloting">
                      <set_value name="$BestPiloting" exact="$NPC_Piloting" />
                      <set_value name="$BestCandidate" exact="$Template" />
                      <set_value name="$BestSource" exact="$PShip" />
                      <set_value name="$BestSeed" exact="$Seed" />
                    </do_if>
                  </do_if>
                </do_all>
              </do_if>
            </do_all>
          </do_if>

          <!-- 후보 발견 시 배정 -->
          <do_if value="$BestCandidate">
            <!-- 템플릿이 이미 인스턴스로 존재하는가? -->
            <set_value name="$TargetActor" exact="$BestSource.roleentity.{$BestCandidate}" />
            
            <do_if value="not $TargetActor.exists">
              <!-- 인스턴스가 없으므로 템플릿으로부터 NPC 인스턴스 생성 -->
              <create_npc_from_template name="$TargetActor" object="$BestSource" template="$BestCandidate" owner="faction.player" placementobject="$Ship" required="true" />
            </do_if>

            <do_if value="$TargetActor.exists">
              <debug_text text="'[SCM] Assigning ' + $TargetActor.knownname + ' (skill ' + $BestPiloting + ') to ' + $Ship.knownname" filter="general" />
              <assign_control_entity actor="$TargetActor" object="$Ship" role="controlrole.pilot" post="controlpost.aipilot" transfer="true" init="true" />
              
              <!-- 중복 배정 방지를 위해 선발된 템플릿과 시드 등록 -->
              <append_to_list name="$AssignedCandidates" exact="$BestCandidate" />
              <do_if value="$BestSeed gt 0">
                <append_to_list name="$AssignedSeeds" exact="$BestSeed" />
              </do_if>

              <!-- 이적이 완료되었으므로 소스 배에서 템플릿 제거 -->
              <do_if value="$BestSource.people.{$BestCandidate}.exists">
                <remove_npc_template object="$BestSource" template="$BestCandidate" />
              </do_if>

              <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{23}.[$Ship.knownname, ($BestPiloting / 3), $TargetActor.knownname]" post="true" />
            </do_if>
            <do_else>
              <debug_text text="'[SCM] Failed to instantiate candidate: ' + $BestCandidate + ' for ' + $Ship.knownname" filter="general" />
            </do_else>
          </do_if>
        </do_all>
      </actions>
    </cue>

    <!-- ============================================================
         5. 미배정 인원 일괄 이동 콜백
         - 플레이어 소유의 모든 함선/스테이션의 미배정 인원 탐색
         - 1차스킬 * 3 + 사기 기준으로 정렬하여 우수한 인원부터 대상 함선에 가득 채움
         ============================================================ -->
    <cue name="scm_fill_unassigned_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="$Ship" exact="event.param.$object" />
        <do_if value="@$Ship.isclass.ship and $Ship.isplayerowned">
          <set_value name="$FreeSlots" exact="$Ship.people.free" />
          <do_if value="$FreeSlots gt 0">
            <!-- 1. 플레이어 함선 및 스테이션 리스트 조회 -->
            <find_ship name="$PlayerShips" owner="faction.player" multiple="true" space="player.galaxy" recursive="true" />
            <find_station name="$PlayerStations" owner="faction.player" multiple="true" space="player.galaxy" />

            <create_list name="$AllSources" />
            <do_all exact="$PlayerShips.count" counter="$s">
              <append_to_list name="$AllSources" exact="$PlayerShips.{$s}" />
            </do_all>
            <do_all exact="$PlayerStations.count" counter="$s">
              <append_to_list name="$AllSources" exact="$PlayerStations.{$s}" />
            </do_all>

            <!-- 2. 미배정 후보군(Candidate) 모으기 -->
            <create_list name="$Candidates" />
            <do_all exact="$AllSources.count" counter="$s">
              <set_value name="$Source" exact="$AllSources.{$s}" />
              <!-- 대상 함선 자신은 원천 배제 -->
              <do_if value="$Source != $Ship">
                <set_value name="$People" exact="$Source.people.list" />
                <do_all exact="$People.count" counter="$p">
                  <set_value name="$Template" exact="$People.{$p}" />
                  <set_value name="$Role" exact="$Source.people.{$Template}.role" />
                  <do_if value="$Role == entityrole.unassigned">
                    <!-- 스킬 점수 계산 (4개 스킬 중 최댓값 * 3 + 사기) -->
                    <set_value name="$MaxBase" exact="0" />
                    <set_value name="$MaxBase" exact="[
                      $Source.people.{$Template}.skill.piloting,
                      $Source.people.{$Template}.skill.engineering,
                      $Source.people.{$Template}.skill.boarding,
                      $Source.people.{$Template}.skill.management
                    ].max" />
                    <set_value name="$Morale" exact="$Source.people.{$Template}.skill.morale" />
                    <set_value name="$Score" exact="($MaxBase * 3) + $Morale" />

                    <append_to_list name="$Candidates" exact="table[
                      $source = $Source,
                      $template = $Template,
                      $score = $Score
                    ]" />
                  </do_if>
                </do_all>
              </do_if>
            </do_all>

            <debug_text text="'[SCM] Found ' + $Candidates.count + ' unassigned candidates. Capacity left: ' + $FreeSlots" filter="general" />

            <!-- 3. 점수가 가장 우수한 선원을 순서대로 $FreeSlots 만큼 선발 -->
            <create_list name="$SelectedCandidates" />
            <set_value name="$LoopCount" exact="if $FreeSlots lt $Candidates.count then $FreeSlots else $Candidates.count" />

            <do_all exact="$LoopCount">
              <set_value name="$BestIdx" exact="0" />
              <set_value name="$BestScore" exact="-1" />
              <do_all exact="$Candidates.count" counter="$idx">
                <do_if value="$Candidates.{$idx}.$score gt $BestScore">
                  <set_value name="$BestScore" exact="$Candidates.{$idx}.$score" />
                  <set_value name="$BestIdx" exact="$idx" />
                </do_if>
              </do_all>
              <do_if value="$BestIdx gt 0">
                <append_to_list name="$SelectedCandidates" exact="$Candidates.{$BestIdx}" />
                <remove_from_list name="$Candidates" exact="$Candidates.{$BestIdx}" />
              </do_if>
            </do_all>

            <!-- 4. 소스별로 분류하여 이전 처리 실행 -->
            <create_list name="$UniqueSources" />
            <do_all exact="$SelectedCandidates.count" counter="$i">
              <set_value name="$Src" exact="$SelectedCandidates.{$i}.$source" />
              <do_if value="not $UniqueSources.indexof.{$Src}">
                <append_to_list name="$UniqueSources" exact="$Src" />
              </do_if>
            </do_all>

            <set_value name="$TotalTransferred" exact="0" />
            <do_all exact="$UniqueSources.count" counter="$s">
              <set_value name="$Src" exact="$UniqueSources.{$s}" />
              <create_list name="$LocalTemplates" />
              <do_all exact="$SelectedCandidates.count" counter="$i">
                <do_if value="$SelectedCandidates.{$i}.$source == $Src">
                  <append_to_list name="$LocalTemplates" exact="$SelectedCandidates.{$i}.$template" />
                </do_if>
              </do_all>

              <do_if value="$LocalTemplates.count gt 0">
                <debug_text text="'[SCM] Transferring ' + $LocalTemplates.count + ' templates from ' + $Src.knownname + ' to ' + $Ship.knownname" filter="general" />
                <transfer_people object="$Ship" otherobject="$Src" result="$Transferred" force="true">
                  <existing_people people="$LocalTemplates" />
                </transfer_people>
                <set_value name="$TotalTransferred" exact="$TotalTransferred + $Transferred.count" />
              </do_if>
            </do_all>

            <!-- 5. 결과 알림 및 로그 작성 -->
            <do_if value="$TotalTransferred gt 0">
              <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{24}.[$Ship.knownname, $TotalTransferred]" post="true" />
              <show_notification text="readtext.{98765}.{24}.[$Ship.knownname, $TotalTransferred]" timeout="6s" />
            </do_if>
          </do_if>
        </do_if>
      </actions>
    </cue>

    <!-- ============================================================
         6. 세미나 일괄 사용 콜백
         - 선택한 함선들의 함장 조종 스킬 체크
         - 필요 세미나 인벤토리 보유 여부 체크 후 1개 차감 & 스킬 업
         ============================================================ -->
    <cue name="scm_use_seminar_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- 전체 선택 함선 리스트 빌드 -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <set_value name="$SuccessCount" exact="0" />
        <set_value name="$Used_0" exact="0" />
        <set_value name="$Used_1" exact="0" />
        <set_value name="$Used_2" exact="0" />
        <set_value name="$Used_3" exact="0" />
        <set_value name="$Used_4" exact="0" />

        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            <set_value name="$Piloting" exact="$Pilot.skill.piloting" />
            
            <do_if value="$Piloting lt 15">
              <set_value name="$TargetSeminar" exact="null" />
              <set_value name="$TargetSkillVal" exact="if ($Piloting + 3) gt 15 then 15 else ($Piloting + 3)" />
              <set_value name="$SeminarIndex" exact="-1" />

              <!-- 실제 바닐라 세미나 매핑 규칙 적용 (5단계) -->
              <do_if value="$Piloting lt 3">
                <!-- 1성 미만 -> 기본 조종 세미나 -->
                <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_0" />
                <set_value name="$SeminarIndex" exact="0" />
              </do_if>
              <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                <!-- 1성대 -> 1성 조종 세미나 -->
                <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_1" />
                <set_value name="$SeminarIndex" exact="1" />
              </do_elseif>
              <do_elseif value="$Piloting ge 6 and $Piloting lt 9">
                <!-- 2성대 -> 2성 조종 세미나 -->
                <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_2" />
                <set_value name="$SeminarIndex" exact="2" />
              </do_elseif>
              <do_elseif value="$Piloting ge 9 and $Piloting lt 12">
                <!-- 3성대 -> 3성 조종 세미나 -->
                <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_3" />
                <set_value name="$SeminarIndex" exact="3" />
              </do_elseif>
              <do_elseif value="$Piloting ge 12 and $Piloting lt 15">
                <!-- 4성대 -> 4성 조종 세미나 -->
                <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_4" />
                <set_value name="$SeminarIndex" exact="4" />
              </do_elseif>

              <!-- 플레이어 인벤토리에 세미나가 있는지 체크하고 사용 -->
              <do_if value="$TargetSeminar != null and player.entity.inventory.{$TargetSeminar}.count gt 0">
                <remove_inventory entity="player.entity" ware="$TargetSeminar" exact="1" />
                <set_skill entity="$Pilot" type="skilltype.piloting" exact="$TargetSkillVal" />
                
                <set_value name="$SuccessCount" exact="$SuccessCount + 1" />
                
                <do_if value="$SeminarIndex == 0">
                  <set_value name="$Used_0" exact="$Used_0 + 1" />
                </do_if>
                <do_if value="$SeminarIndex == 1">
                  <set_value name="$Used_1" exact="$Used_1 + 1" />
                </do_if>
                <do_if value="$SeminarIndex == 2">
                  <set_value name="$Used_2" exact="$Used_2 + 1" />
                </do_if>
                <do_if value="$SeminarIndex == 3">
                  <set_value name="$Used_3" exact="$Used_3 + 1" />
                </do_if>
                <do_if value="$SeminarIndex == 4">
                  <set_value name="$Used_4" exact="$Used_4 + 1" />
                </do_if>
              </do_if>
            </do_if>
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Use Seminar finished. Promoted ' + $SuccessCount + ' captains'" filter="general" />

        <!-- 결과 피드백 작성 -->
        <do_if value="$SuccessCount gt 0">
          <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{25}.[$SuccessCount, $Used_0, $Used_1, $Used_2, $Used_3, $Used_4]" post="true" />
          <show_notification text="readtext.{98765}.{25}.[$SuccessCount, $Used_0, $Used_1, $Used_2, $Used_3, $Used_4]" timeout="6s" />
        </do_if>
      </actions>
    </cue>

  </cues>
</mdscript>
