<?xml version="1.0" encoding="utf-8"?>
<mdscript name="SCM" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>

    <!-- ============================================================
         1. Register Actions on Menu Open
         - SN Mod Support APIs: md.Interact_Menu_API.Get_Actions
         ============================================================ -->
    <cue name="SCM_get_actions" instantiate="true">
      <conditions>
        <event_cue_signalled cue="@md.Interact_Menu_API.Get_Actions" />
        <check_value value="@event.param.$object.isclass.ship or @event.param.$object.isclass.station" />
        <check_value value="@event.param.$object.isplayerowned" />
      </conditions>
      <actions>
        <!-- Build list of selected ships (right-clicked object + other selected player-owned ships) -->
        <create_list name="$Ships" />
        <set_value name="$IsStation" exact="event.param.$object.isclass.station" />
        
        <do_if value="(@event.param.$object.isclass.ship or @event.param.$object.isclass.station) and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        
        <!-- Only gather selected ships if the main target is not a station -->
        <do_if value="not $IsStation">
          <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
            <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
            <do_if value="@$SelShip.isclass.ship and $SelShip.isplayerowned">
              <do_if value="not $Ships.indexof.{$SelShip}">
                <append_to_list name="$Ships" exact="$SelShip" />
              </do_if>
            </do_if>
          </do_all>
        </do_if>
 
        <set_value name="$ShipsCount" exact="$Ships.count" />
        <do_if value="$ShipsCount gt 0">
          <!-- Determine Kuertee UI Extensions section names based on selection count and register groups -->
          <set_value name="$s_assign" exact="if $ShipsCount gt 1 then 'orders_scm_assign' else 'actions_scm_assign'" />
          <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Id'" param="$s_assign" />
          <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Text'" param="readtext.{98765}.{10}" />

          <set_value name="$s_seminar" exact="if $ShipsCount gt 1 then 'orders_scm_seminar' else 'actions_scm_seminar'" />
          <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Id'" param="$s_seminar" />
          <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Text'" param="readtext.{98765}.{11}" />

          <set_value name="$s_other" exact="if $ShipsCount gt 1 then 'orders_scm_other' else 'actions_scm_other'" />
          <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Id'" param="$s_other" />
          <raise_lua_event name="'Interact_Menu_API.Add_Custom_Actions_Group_Text'" param="readtext.{98765}.{12}" />
  
          <!-- 1. Assign Captain Group -->
          <do_if value="not $IsStation">
            <set_value name="$ReqAssignCount" exact="0" />
            <do_all exact="$Ships.count" counter="$i">
              <do_if value="not @$Ships.{$i}.pilot">
                <set_value name="$ReqAssignCount" exact="$ReqAssignCount + 1" />
              </do_if>
            </do_all>

            <set_value name="$Avail_all" exact="0" />
            <set_value name="$Avail_5star" exact="0" />
            <set_value name="$Avail_4star" exact="0" />
            <set_value name="$Avail_3star" exact="0" />
            <set_value name="$Avail_2star" exact="0" />
            <set_value name="$Avail_1star" exact="0" />
            <set_value name="$Avail_under5" exact="0" />
            <set_value name="$Avail_under4" exact="0" />
            <set_value name="$Avail_under3" exact="0" />
            <set_value name="$Avail_under2" exact="0" />
            <set_value name="$Avail_under1" exact="0" />

            <!-- Count unassigned crew galaxy-wide if there is at least one empty ship -->
            <do_if value="$ReqAssignCount gt 0">
              <find_ship name="$PlayerShipsForCount" owner="faction.player" multiple="true" space="player.galaxy" recursive="true" />
              <find_station name="$PlayerStationsForCount" owner="faction.player" multiple="true" space="player.galaxy" />

              <create_list name="$AllSourcesForCount" />
              <do_all exact="$PlayerShipsForCount.count" counter="$s">
                <append_to_list name="$AllSourcesForCount" exact="$PlayerShipsForCount.{$s}" />
              </do_all>
              <do_all exact="$PlayerStationsForCount.count" counter="$s">
                <append_to_list name="$AllSourcesForCount" exact="$PlayerStationsForCount.{$s}" />
              </do_all>

              <do_all exact="$AllSourcesForCount.count" counter="$j">
                <set_value name="$PSource" exact="$AllSourcesForCount.{$j}" />
                <set_value name="$SourcePeople" exact="$PSource.people.list" />
                <do_all exact="$SourcePeople.count" counter="$k">
                  <set_value name="$Template" exact="$SourcePeople.{$k}" />
                  <do_if value="$PSource.people.{$Template}.role == entityrole.unassigned">
                    <set_value name="$Skill" exact="$PSource.people.{$Template}.skill.{skilltype.piloting}" />
                    <set_value name="$Avail_all" exact="$Avail_all + 1" />
                    <do_if value="$Skill ge 15">
                      <set_value name="$Avail_5star" exact="$Avail_5star + 1" />
                    </do_if>
                    <do_if value="$Skill ge 12">
                      <set_value name="$Avail_4star" exact="$Avail_4star + 1" />
                    </do_if>
                    <do_if value="$Skill ge 9">
                      <set_value name="$Avail_3star" exact="$Avail_3star + 1" />
                    </do_if>
                    <do_if value="$Skill ge 6">
                      <set_value name="$Avail_2star" exact="$Avail_2star + 1" />
                    </do_if>
                    <do_if value="$Skill ge 3">
                      <set_value name="$Avail_1star" exact="$Avail_1star + 1" />
                    </do_if>
                    <do_if value="$Skill lt 15">
                      <set_value name="$Avail_under5" exact="$Avail_under5 + 1" />
                    </do_if>
                    <do_if value="$Skill lt 12">
                      <set_value name="$Avail_under4" exact="$Avail_under4 + 1" />
                    </do_if>
                    <do_if value="$Skill lt 9">
                      <set_value name="$Avail_under3" exact="$Avail_under3 + 1" />
                    </do_if>
                    <do_if value="$Skill lt 6">
                      <set_value name="$Avail_under2" exact="$Avail_under2 + 1" />
                    </do_if>
                    <do_if value="$Skill lt 3">
                      <set_value name="$Avail_under1" exact="$Avail_under1 + 1" />
                    </do_if>
                  </do_if>
                </do_all>
              </do_all>
            </do_if>

            <!-- Determine active state for each individual action -->
            <set_value name="$Active_assign_all" exact="$ReqAssignCount gt 0 and $Avail_all gt 0" />
            <set_value name="$Active_assign_5star" exact="$ReqAssignCount gt 0 and $Avail_5star gt 0" />
            <set_value name="$Active_assign_4star" exact="$ReqAssignCount gt 0 and $Avail_4star gt 0" />
            <set_value name="$Active_assign_3star" exact="$ReqAssignCount gt 0 and $Avail_3star gt 0" />
            <set_value name="$Active_assign_2star" exact="$ReqAssignCount gt 0 and $Avail_2star gt 0" />
            <set_value name="$Active_assign_1star" exact="$ReqAssignCount gt 0 and $Avail_1star gt 0" />
            <set_value name="$Active_assign_under_5star" exact="$ReqAssignCount gt 0 and $Avail_under5 gt 0" />
            <set_value name="$Active_assign_under_4star" exact="$ReqAssignCount gt 0 and $Avail_under4 gt 0" />
            <set_value name="$Active_assign_under_3star" exact="$ReqAssignCount gt 0 and $Avail_under3 gt 0" />
            <set_value name="$Active_assign_under_2star" exact="$ReqAssignCount gt 0 and $Avail_under2 gt 0" />
            <set_value name="$Active_assign_under_1star" exact="$ReqAssignCount gt 0 and $Avail_under1 gt 0" />

            <!-- Set up Assign Tooltips based on Active status of each option -->
            <set_value name="$AssignMouseover_all" exact="if not $Active_assign_all then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{417}) else readtext.{98765}.{205}" />
            <set_value name="$AssignMouseover_5star" exact="if not $Active_assign_5star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{418}) else readtext.{98765}.{204}" />
            <set_value name="$AssignMouseover_4star" exact="if not $Active_assign_4star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{419}) else readtext.{98765}.{209}" />
            <set_value name="$AssignMouseover_3star" exact="if not $Active_assign_3star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{420}) else readtext.{98765}.{206}" />
            <set_value name="$AssignMouseover_2star" exact="if not $Active_assign_2star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{421}) else readtext.{98765}.{207}" />
            <set_value name="$AssignMouseover_1star" exact="if not $Active_assign_1star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{422}) else readtext.{98765}.{210}" />
            <set_value name="$AssignMouseover_under_5star" exact="if not $Active_assign_under_5star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{423}) else readtext.{98765}.{211}" />
            <set_value name="$AssignMouseover_under_4star" exact="if not $Active_assign_under_4star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{424}) else readtext.{98765}.{212}" />
            <set_value name="$AssignMouseover_under_3star" exact="if not $Active_assign_under_3star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{425}) else readtext.{98765}.{213}" />
            <set_value name="$AssignMouseover_under_2star" exact="if not $Active_assign_under_2star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{426}) else readtext.{98765}.{208}" />
            <set_value name="$AssignMouseover_under_1star" exact="if not $Active_assign_under_1star then (if $ReqAssignCount == 0 then readtext.{98765}.{401} else readtext.{98765}.{427}) else readtext.{98765}.{214}" />

            <!-- Add shortage/mixed warning strings when unassigned crew is insufficient or selection is mixed -->
            <do_if value="$ReqAssignCount gt 0">
              <set_value name="$ShortCrew_all" exact="if ($ReqAssignCount - $Avail_all) gt 0 then ($ReqAssignCount - $Avail_all) else 0" />
              <set_value name="$ShortCrew_5star" exact="if ($ReqAssignCount - $Avail_5star) gt 0 then ($ReqAssignCount - $Avail_5star) else 0" />
              <set_value name="$ShortCrew_4star" exact="if ($ReqAssignCount - $Avail_4star) gt 0 then ($ReqAssignCount - $Avail_4star) else 0" />
              <set_value name="$ShortCrew_3star" exact="if ($ReqAssignCount - $Avail_3star) gt 0 then ($ReqAssignCount - $Avail_3star) else 0" />
              <set_value name="$ShortCrew_2star" exact="if ($ReqAssignCount - $Avail_2star) gt 0 then ($ReqAssignCount - $Avail_2star) else 0" />
              <set_value name="$ShortCrew_1star" exact="if ($ReqAssignCount - $Avail_1star) gt 0 then ($ReqAssignCount - $Avail_1star) else 0" />
              <set_value name="$ShortCrew_under5" exact="if ($ReqAssignCount - $Avail_under5) gt 0 then ($ReqAssignCount - $Avail_under5) else 0" />
              <set_value name="$ShortCrew_under4" exact="if ($ReqAssignCount - $Avail_under4) gt 0 then ($ReqAssignCount - $Avail_under4) else 0" />
              <set_value name="$ShortCrew_under3" exact="if ($ReqAssignCount - $Avail_under3) gt 0 then ($ReqAssignCount - $Avail_under3) else 0" />
              <set_value name="$ShortCrew_under2" exact="if ($ReqAssignCount - $Avail_under2) gt 0 then ($ReqAssignCount - $Avail_under2) else 0" />
              <set_value name="$ShortCrew_under1" exact="if ($ReqAssignCount - $Avail_under1) gt 0 then ($ReqAssignCount - $Avail_under1) else 0" />

              <set_value name="$AlreadyPilotShips" exact="$ShipsCount - $ReqAssignCount" />

              <!-- 1. All -->
              <do_if value="$Active_assign_all">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_all gt 0">
                    <set_value name="$AssignMouseover_all" exact="$AssignMouseover_all + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_all]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_all" exact="$AssignMouseover_all + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_all gt 0">
                    <set_value name="$AssignMouseover_all" exact="$AssignMouseover_all + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_all" exact="$AssignMouseover_all + '\n' + readtext.{98765}.{250}.[$Avail_all]" />
              </do_if>

              <!-- 2. 5star -->
              <do_if value="$Active_assign_5star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_5star gt 0">
                    <set_value name="$AssignMouseover_5star" exact="$AssignMouseover_5star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_5star]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_5star" exact="$AssignMouseover_5star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_5star gt 0">
                    <set_value name="$AssignMouseover_5star" exact="$AssignMouseover_5star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_5star" exact="$AssignMouseover_5star + '\n' + readtext.{98765}.{251}.[$Avail_5star]" />
              </do_if>

              <!-- 3. 4star -->
              <do_if value="$Active_assign_4star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_4star gt 0">
                    <set_value name="$AssignMouseover_4star" exact="$AssignMouseover_4star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_4star]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_4star" exact="$AssignMouseover_4star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_4star gt 0">
                    <set_value name="$AssignMouseover_4star" exact="$AssignMouseover_4star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_4star" exact="$AssignMouseover_4star + '\n' + readtext.{98765}.{252}.[$Avail_4star]" />
              </do_if>

              <!-- 4. 3star -->
              <do_if value="$Active_assign_3star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_3star gt 0">
                    <set_value name="$AssignMouseover_3star" exact="$AssignMouseover_3star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_3star]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_3star" exact="$AssignMouseover_3star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_3star gt 0">
                    <set_value name="$AssignMouseover_3star" exact="$AssignMouseover_3star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_3star" exact="$AssignMouseover_3star + '\n' + readtext.{98765}.{253}.[$Avail_3star]" />
              </do_if>

              <!-- 5. 2star -->
              <do_if value="$Active_assign_2star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_2star gt 0">
                    <set_value name="$AssignMouseover_2star" exact="$AssignMouseover_2star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_2star]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_2star" exact="$AssignMouseover_2star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_2star gt 0">
                    <set_value name="$AssignMouseover_2star" exact="$AssignMouseover_2star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_2star" exact="$AssignMouseover_2star + '\n' + readtext.{98765}.{254}.[$Avail_2star]" />
              </do_if>

              <!-- 6. 1star -->
              <do_if value="$Active_assign_1star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_1star gt 0">
                    <set_value name="$AssignMouseover_1star" exact="$AssignMouseover_1star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_1star]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_1star" exact="$AssignMouseover_1star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_1star gt 0">
                    <set_value name="$AssignMouseover_1star" exact="$AssignMouseover_1star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_1star" exact="$AssignMouseover_1star + '\n' + readtext.{98765}.{255}.[$Avail_1star]" />
              </do_if>

              <!-- 7. under5 -->
              <do_if value="$Active_assign_under_5star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_under5 gt 0">
                    <set_value name="$AssignMouseover_under_5star" exact="$AssignMouseover_under_5star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_under5]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_under_5star" exact="$AssignMouseover_under_5star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_under5 gt 0">
                    <set_value name="$AssignMouseover_under_5star" exact="$AssignMouseover_under_5star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_under_5star" exact="$AssignMouseover_under_5star + '\n' + readtext.{98765}.{256}.[$Avail_under5]" />
              </do_if>

              <!-- 8. under4 -->
              <do_if value="$Active_assign_under_4star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_under4 gt 0">
                    <set_value name="$AssignMouseover_under_4star" exact="$AssignMouseover_under_4star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_under4]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_under_4star" exact="$AssignMouseover_under_4star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_under4 gt 0">
                    <set_value name="$AssignMouseover_under_4star" exact="$AssignMouseover_under_4star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_under_4star" exact="$AssignMouseover_under_4star + '\n' + readtext.{98765}.{257}.[$Avail_under4]" />
              </do_if>

              <!-- 9. under3 -->
              <do_if value="$Active_assign_under_3star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_under3 gt 0">
                    <set_value name="$AssignMouseover_under_3star" exact="$AssignMouseover_under_3star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_under3]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_under_3star" exact="$AssignMouseover_under_3star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_under3 gt 0">
                    <set_value name="$AssignMouseover_under_3star" exact="$AssignMouseover_under_3star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_under_3star" exact="$AssignMouseover_under_3star + '\n' + readtext.{98765}.{258}.[$Avail_under3]" />
              </do_if>

              <!-- 10. under2 -->
              <do_if value="$Active_assign_under_2star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_under2 gt 0">
                    <set_value name="$AssignMouseover_under_2star" exact="$AssignMouseover_under_2star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_under2]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_under_2star" exact="$AssignMouseover_under_2star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_under2 gt 0">
                    <set_value name="$AssignMouseover_under_2star" exact="$AssignMouseover_under_2star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_under_2star" exact="$AssignMouseover_under_2star + '\n' + readtext.{98765}.{259}.[$Avail_under2]" />
              </do_if>

              <!-- 11. under1 -->
              <do_if value="$Active_assign_under_1star">
                <do_if value="$AlreadyPilotShips gt 0">
                  <do_if value="$ShortCrew_under1 gt 0">
                    <set_value name="$AssignMouseover_under_1star" exact="$AssignMouseover_under_1star + '\n' + readtext.{98765}.{416}.[$AlreadyPilotShips, $Avail_under1]" />
                  </do_if>
                  <do_else>
                    <set_value name="$AssignMouseover_under_1star" exact="$AssignMouseover_under_1star + '\n' + readtext.{98765}.{415}.[$AlreadyPilotShips, $ReqAssignCount]" />
                  </do_else>
                </do_if>
                <do_else>
                  <do_if value="$ShortCrew_under1 gt 0">
                    <set_value name="$AssignMouseover_under_1star" exact="$AssignMouseover_under_1star + '\n' + readtext.{98765}.{414}" />
                  </do_if>
                </do_else>
                <set_value name="$AssignMouseover_under_1star" exact="$AssignMouseover_under_1star + '\n' + readtext.{98765}.{260}.[$Avail_under1]" />
              </do_if>
            </do_if>

            <!-- 1.1 Assign All -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_all',
                $section  = $s_assign,
                $text     = readtext.{98765}.{100},
                $mouseover = $AssignMouseover_all,
                $active   = $Active_assign_all,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.2 Assign 5-star only -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_5star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{101},
                $mouseover = $AssignMouseover_5star,
                $active   = $Active_assign_5star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.3 Assign 4-star and higher -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_4star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{102},
                $mouseover = $AssignMouseover_4star,
                $active   = $Active_assign_4star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.4 Assign 3-star and higher -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_3star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{103},
                $mouseover = $AssignMouseover_3star,
                $active   = $Active_assign_3star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.5 Assign 2-star and higher -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_2star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{104},
                $mouseover = $AssignMouseover_2star,
                $active   = $Active_assign_2star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.6 Assign 1-star and higher -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_1star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{105},
                $mouseover = $AssignMouseover_1star,
                $active   = $Active_assign_1star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.7 Assign under 5-star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_under_5star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{106},
                $mouseover = $AssignMouseover_under_5star,
                $active   = $Active_assign_under_5star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.8 Assign under 4-star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_under_4star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{107},
                $mouseover = $AssignMouseover_under_4star,
                $active   = $Active_assign_under_4star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.9 Assign under 3-star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_under_3star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{108},
                $mouseover = $AssignMouseover_under_3star,
                $active   = $Active_assign_under_3star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.10 Assign under 2-star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_rookie',
                $section  = $s_assign,
                $text     = readtext.{98765}.{109},
                $mouseover = $AssignMouseover_under_2star,
                $active   = $Active_assign_under_2star,
                $callback = SCM_assign_callback,
                ]" />

            <!-- 1.11 Assign under 1-star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_assign_under_1star',
                $section  = $s_assign,
                $text     = readtext.{98765}.{110},
                $mouseover = $AssignMouseover_under_1star,
                $active   = $Active_assign_under_1star,
                $callback = SCM_assign_callback,
                ]" />
          </do_if>
  
          <!-- 2. Use Seminars Group -->
          <do_if value="not $IsStation">
            <set_value name="$SeminarActive" exact="false" />

            <set_value name="$HasSem_0" exact="player.entity.inventory.{ware.inv_seminar_piloting_0}.count" />
            <set_value name="$HasSem_1" exact="player.entity.inventory.{ware.inv_seminar_piloting_1}.count" />
            <set_value name="$HasSem_2" exact="player.entity.inventory.{ware.inv_seminar_piloting_2}.count" />
            <set_value name="$HasSem_3" exact="player.entity.inventory.{ware.inv_seminar_piloting_3}.count" />
            <set_value name="$HasSem_4" exact="player.entity.inventory.{ware.inv_seminar_piloting_4}.count" />
            <set_value name="$AnySeminar" exact="$HasSem_0 + $HasSem_1 + $HasSem_2 + $HasSem_3 + $HasSem_4 gt 0" />

            <set_value name="$Req1_0" exact="0" />
            <set_value name="$Req2_0" exact="0" />
            <set_value name="$Req2_1" exact="0" />
            <set_value name="$Req3_0" exact="0" />
            <set_value name="$Req3_1" exact="0" />
            <set_value name="$Req3_2" exact="0" />
            <set_value name="$Req4_0" exact="0" />
            <set_value name="$Req4_1" exact="0" />
            <set_value name="$Req4_2" exact="0" />
            <set_value name="$Req4_3" exact="0" />
            <set_value name="$ReqMax_0" exact="0" />
            <set_value name="$ReqMax_1" exact="0" />
            <set_value name="$ReqMax_2" exact="0" />
            <set_value name="$ReqMax_3" exact="0" />
            <set_value name="$ReqMax_4" exact="0" />
            <set_value name="$ReqSingle_0" exact="0" />
            <set_value name="$ReqSingle_1" exact="0" />
            <set_value name="$ReqSingle_2" exact="0" />
            <set_value name="$ReqSingle_3" exact="0" />
            <set_value name="$ReqSingle_4" exact="0" />

            <do_all exact="$Ships.count" counter="$i">
              <do_if value="@$Ships.{$i}.pilot.exists">
                <set_value name="$SeminarActive" exact="true" />
                <set_value name="$Piloting" exact="$Ships.{$i}.pilot.skill.piloting" />

                <!-- 1star (up to 3) -->
                <do_if value="$Piloting lt 3">
                  <set_value name="$Req1_0" exact="$Req1_0 + 1" />
                </do_if>

                <!-- 2star (up to 6) -->
                <do_if value="$Piloting lt 3">
                  <set_value name="$Req2_0" exact="$Req2_0 + 1" />
                  <set_value name="$Req2_1" exact="$Req2_1 + 1" />
                </do_if>
                <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                  <set_value name="$Req2_1" exact="$Req2_1 + 1" />
                </do_elseif>

                <!-- 3star (up to 9) -->
                <do_if value="$Piloting lt 3">
                  <set_value name="$Req3_0" exact="$Req3_0 + 1" />
                  <set_value name="$Req3_1" exact="$Req3_1 + 1" />
                  <set_value name="$Req3_2" exact="$Req3_2 + 1" />
                </do_if>
                <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                  <set_value name="$Req3_1" exact="$Req3_1 + 1" />
                  <set_value name="$Req3_2" exact="$Req3_2 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 6 and $Piloting lt 9">
                  <set_value name="$Req3_2" exact="$Req3_2 + 1" />
                </do_elseif>

                <!-- 4star (up to 12) -->
                <do_if value="$Piloting lt 3">
                  <set_value name="$Req4_0" exact="$Req4_0 + 1" />
                  <set_value name="$Req4_1" exact="$Req4_1 + 1" />
                  <set_value name="$Req4_2" exact="$Req4_2 + 1" />
                  <set_value name="$Req4_3" exact="$Req4_3 + 1" />
                </do_if>
                <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                  <set_value name="$Req4_1" exact="$Req4_1 + 1" />
                  <set_value name="$Req4_2" exact="$Req4_2 + 1" />
                  <set_value name="$Req4_3" exact="$Req4_3 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 6 and $Piloting lt 9">
                  <set_value name="$Req4_2" exact="$Req4_2 + 1" />
                  <set_value name="$Req4_3" exact="$Req4_3 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 9 and $Piloting lt 12">
                  <set_value name="$Req4_3" exact="$Req4_3 + 1" />
                </do_elseif>

                <!-- Max (up to 15) -->
                <do_if value="$Piloting lt 3">
                  <set_value name="$ReqMax_0" exact="$ReqMax_0 + 1" />
                  <set_value name="$ReqMax_1" exact="$ReqMax_1 + 1" />
                  <set_value name="$ReqMax_2" exact="$ReqMax_2 + 1" />
                  <set_value name="$ReqMax_3" exact="$ReqMax_3 + 1" />
                  <set_value name="$ReqMax_4" exact="$ReqMax_4 + 1" />
                </do_if>
                <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                  <set_value name="$ReqMax_1" exact="$ReqMax_1 + 1" />
                  <set_value name="$ReqMax_2" exact="$ReqMax_2 + 1" />
                  <set_value name="$ReqMax_3" exact="$ReqMax_3 + 1" />
                  <set_value name="$ReqMax_4" exact="$ReqMax_4 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 6 and $Piloting lt 9">
                  <set_value name="$ReqMax_2" exact="$ReqMax_2 + 1" />
                  <set_value name="$ReqMax_3" exact="$ReqMax_3 + 1" />
                  <set_value name="$ReqMax_4" exact="$ReqMax_4 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 9 and $Piloting lt 12">
                  <set_value name="$ReqMax_3" exact="$ReqMax_3 + 1" />
                  <set_value name="$ReqMax_4" exact="$ReqMax_4 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 12 and $Piloting lt 15">
                  <set_value name="$ReqMax_4" exact="$ReqMax_4 + 1" />
                </do_elseif>

                <!-- Single (only 1 level) -->
                <do_if value="$Piloting lt 3">
                  <set_value name="$ReqSingle_0" exact="$ReqSingle_0 + 1" />
                </do_if>
                <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                  <set_value name="$ReqSingle_1" exact="$ReqSingle_1 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 6 and $Piloting lt 9">
                  <set_value name="$ReqSingle_2" exact="$ReqSingle_2 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 9 and $Piloting lt 12">
                  <set_value name="$ReqSingle_3" exact="$ReqSingle_3 + 1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 12 and $Piloting lt 15">
                  <set_value name="$ReqSingle_4" exact="$ReqSingle_4 + 1" />
                </do_elseif>
              </do_if>
            </do_all>

            <set_value name="$SubmenuActive" exact="$SeminarActive and $AnySeminar" />

            <!-- Calculate shortages -->
            <set_value name="$Short1_0" exact="if ($Req1_0 - $HasSem_0) gt 0 then ($Req1_0 - $HasSem_0) else 0" />

            <set_value name="$Short2_0" exact="if ($Req2_0 - $HasSem_0) gt 0 then ($Req2_0 - $HasSem_0) else 0" />
            <set_value name="$Short2_1" exact="if ($Req2_1 - $HasSem_1) gt 0 then ($Req2_1 - $HasSem_1) else 0" />

            <set_value name="$Short3_0" exact="if ($Req3_0 - $HasSem_0) gt 0 then ($Req3_0 - $HasSem_0) else 0" />
            <set_value name="$Short3_1" exact="if ($Req3_1 - $HasSem_1) gt 0 then ($Req3_1 - $HasSem_1) else 0" />
            <set_value name="$Short3_2" exact="if ($Req3_2 - $HasSem_2) gt 0 then ($Req3_2 - $HasSem_2) else 0" />

            <set_value name="$Short4_0" exact="if ($Req4_0 - $HasSem_0) gt 0 then ($Req4_0 - $HasSem_0) else 0" />
            <set_value name="$Short4_1" exact="if ($Req4_1 - $HasSem_1) gt 0 then ($Req4_1 - $HasSem_1) else 0" />
            <set_value name="$Short4_2" exact="if ($Req4_2 - $HasSem_2) gt 0 then ($Req4_2 - $HasSem_2) else 0" />
            <set_value name="$Short4_3" exact="if ($Req4_3 - $HasSem_3) gt 0 then ($Req4_3 - $HasSem_3) else 0" />

            <set_value name="$ShortMax_0" exact="if ($ReqMax_0 - $HasSem_0) gt 0 then ($ReqMax_0 - $HasSem_0) else 0" />
            <set_value name="$ShortMax_1" exact="if ($ReqMax_1 - $HasSem_1) gt 0 then ($ReqMax_1 - $HasSem_1) else 0" />
            <set_value name="$ShortMax_2" exact="if ($ReqMax_2 - $HasSem_2) gt 0 then ($ReqMax_2 - $HasSem_2) else 0" />
            <set_value name="$ShortMax_3" exact="if ($ReqMax_3 - $HasSem_3) gt 0 then ($ReqMax_3 - $HasSem_3) else 0" />
            <set_value name="$ShortMax_4" exact="if ($ReqMax_4 - $HasSem_4) gt 0 then ($ReqMax_4 - $HasSem_4) else 0" />

            <set_value name="$ShortSingle_0" exact="if ($ReqSingle_0 - $HasSem_0) gt 0 then ($ReqSingle_0 - $HasSem_0) else 0" />
            <set_value name="$ShortSingle_1" exact="if ($ReqSingle_1 - $HasSem_1) gt 0 then ($ReqSingle_1 - $HasSem_1) else 0" />
            <set_value name="$ShortSingle_2" exact="if ($ReqSingle_2 - $HasSem_2) gt 0 then ($ReqSingle_2 - $HasSem_2) else 0" />
            <set_value name="$ShortSingle_3" exact="if ($ReqSingle_3 - $HasSem_3) gt 0 then ($ReqSingle_3 - $HasSem_3) else 0" />
            <set_value name="$ShortSingle_4" exact="if ($ReqSingle_4 - $HasSem_4) gt 0 then ($ReqSingle_4 - $HasSem_4) else 0" />

            <set_value name="$Active_1star" exact="$SubmenuActive and ($Short1_0 == 0)" />
            <set_value name="$Active_2star" exact="$SubmenuActive and ($Short2_0 == 0) and ($Short2_1 == 0)" />
            <set_value name="$Active_3star" exact="$SubmenuActive and ($Short3_0 == 0) and ($Short3_1 == 0) and ($Short3_2 == 0)" />
            <set_value name="$Active_4star" exact="$SubmenuActive and ($Short4_0 == 0) and ($Short4_1 == 0) and ($Short4_2 == 0) and ($Short4_3 == 0)" />
            <set_value name="$Active_5star" exact="$SubmenuActive and ($ShortMax_0 == 0) and ($ShortMax_1 == 0) and ($ShortMax_2 == 0) and ($ShortMax_3 == 0) and ($ShortMax_4 == 0)" />
            <set_value name="$Active_max" exact="$SubmenuActive" />
            <set_value name="$Active_single" exact="$SubmenuActive and ($ShortSingle_0 == 0) and ($ShortSingle_1 == 0) and ($ShortSingle_2 == 0) and ($ShortSingle_3 == 0) and ($ShortSingle_4 == 0)" />

            <!-- Dynamic single training shortage tooltip configuration for single ship selection -->
            <set_value name="$SingleShortTid" exact="209" />
            <set_value name="$SingleParams" exact="[$ShortSingle_0, $ShortSingle_1, $ShortSingle_2, $ShortSingle_3, $ShortSingle_4]" />
            <do_if value="$Ships.count == 1 and @$Ships.{1}.pilot.exists">
              <set_value name="$PilotSkill" exact="$Ships.{1}.pilot.skill.piloting" />
              <do_if value="$PilotSkill lt 3">
                <set_value name="$SingleShortTid" exact="200" />
                <set_value name="$SingleParams" exact="[]" />
              </do_if>
              <do_elseif value="$PilotSkill ge 3 and $PilotSkill lt 6">
                <set_value name="$SingleShortTid" exact="206" />
                <set_value name="$SingleParams" exact="[$ShortSingle_0, $ShortSingle_1]" />
              </do_elseif>
              <do_elseif value="$PilotSkill ge 6 and $PilotSkill lt 9">
                <set_value name="$SingleShortTid" exact="207" />
                <set_value name="$SingleParams" exact="[$ShortSingle_0, $ShortSingle_1, $ShortSingle_2]" />
              </do_elseif>
              <do_elseif value="$PilotSkill ge 9 and $PilotSkill lt 12">
                <set_value name="$SingleShortTid" exact="208" />
                <set_value name="$SingleParams" exact="[$ShortSingle_0, $ShortSingle_1, $ShortSingle_2, $ShortSingle_3]" />
              </do_elseif>
            </do_if>

            <!-- Set up Seminar Tooltips based on Active status and inventory availability -->
            <set_value name="$SeminarMouseover_1star" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else (if not $Active_1star then readtext.{98765}.{409}.[$Short1_0] else readtext.{98765}.{220}))" />
            <set_value name="$SeminarMouseover_2star" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else (if not $Active_2star then readtext.{98765}.{410}.[$Short2_0, $Short2_1] else readtext.{98765}.{219}))" />
            <set_value name="$SeminarMouseover_3star" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else (if not $Active_3star then readtext.{98765}.{411}.[$Short3_0, $Short3_1, $Short3_2] else readtext.{98765}.{217}))" />
            <set_value name="$SeminarMouseover_4star" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else (if not $Active_4star then readtext.{98765}.{412}.[$Short4_0, $Short4_1, $Short4_2, $Short4_3] else readtext.{98765}.{216}))" />
            <set_value name="$SeminarMouseover_5star" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else (if not $Active_5star then readtext.{98765}.{413}.[$ShortMax_0, $ShortMax_1, $ShortMax_2, $ShortMax_3, $ShortMax_4] else readtext.{98765}.{221}))" />
            <set_value name="$SeminarMouseover_max" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else readtext.{98765}.{215})" />
            <set_value name="$SeminarMouseover_single" exact="if not $SeminarActive then readtext.{98765}.{405} else (if not $AnySeminar then readtext.{98765}.{408} else (if not $Active_single then (if $SingleParams.count gt 0 then readtext.{98765}.{$SingleShortTid}.{$SingleParams} else readtext.{98765}.{$SingleShortTid}) else readtext.{98765}.{218}))" />

            <!-- 2.1 Max Training -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_max',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{120},
                $mouseover = $SeminarMouseover_max,
                $active   = $Active_max,
                $callback = SCM_use_seminar_callback,
                ]" />

            <!-- 2.2 Train to 5-Star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_5star',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{121},
                $mouseover = $SeminarMouseover_5star,
                $active   = $Active_5star,
                $callback = SCM_use_seminar_callback,
                ]" />

            <!-- 2.3 Train to 4-Star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_4star',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{122},
                $mouseover = $SeminarMouseover_4star,
                $active   = $Active_4star,
                $callback = SCM_use_seminar_callback,
                ]" />

            <!-- 2.3 Train to 3-Star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_3star',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{123},
                $mouseover = $SeminarMouseover_3star,
                $active   = $Active_3star,
                $callback = SCM_use_seminar_callback,
                ]" />

            <!-- 2.4 Train to 2-Star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_2star',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{124},
                $mouseover = $SeminarMouseover_2star,
                $active   = $Active_2star,
                $callback = SCM_use_seminar_callback,
                ]" />

            <!-- 2.5 Train to 1-Star -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_1star',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{125},
                $mouseover = $SeminarMouseover_1star,
                $active   = $Active_1star,
                $callback = SCM_use_seminar_callback,
                ]" />

            <!-- 2.6 Use Single Seminar -->
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_seminar_single',
                $section  = $s_seminar,
                $text     = readtext.{98765}.{126},
                $mouseover = $SeminarMouseover_single,
                $active   = $Active_single,
                $callback = SCM_use_seminar_callback,
                ]" />
          </do_if>
  
          <!-- 3. Other Management Group -->
          <do_if value="not $IsStation">
            <!-- 3.1 Fill Unassigned Crew (original text: id="6") -->
            <do_if value="$ShipsCount == 1">
              <set_value name="$FillActive" exact="true" />
              <do_if value="$Ships.{1}.people.free le 0">
                <set_value name="$FillActive" exact="false" />
              </do_if>
              <set_value name="$FillMouseover" exact="if not $FillActive then readtext.{98765}.{407} else readtext.{98765}.{202}" />
              <signal_cue_instantly
                cue="md.Interact_Menu_API.Add_Action"
                param="table[
                  $id       = 'scm_fill_unassigned',
                  $section  = $s_other,
                  $text     = readtext.{98765}.{4},
                  $mouseover = $FillMouseover,
                  $active   = $FillActive,
                  $callback = SCM_fill_unassigned_callback,
                  ]" />
            </do_if>

            <!-- 3.2 relief (dismiss) and fire Captain checks (Check if any ship in selection has a captain) -->
            <set_value name="$HasAnyPilot" exact="false" />
            <set_value name="$HasFullShipWithPilot" exact="false" />
            <do_all exact="$Ships.count" counter="$i">
              <do_if value="@$Ships.{$i}.pilot.exists">
                <set_value name="$HasAnyPilot" exact="true" />
                <do_if value="$Ships.{$i}.people.free le 0">
                  <set_value name="$HasFullShipWithPilot" exact="true" />
                </do_if>
              </do_if>
            </do_all>

            <!-- 3.2 Dismiss Captain (Relief) -->
            <set_value name="$UnassignActive" exact="$HasAnyPilot" />
            <set_value name="$UnassignMouseover" exact="if not $UnassignActive then readtext.{98765}.{400} else (if $HasFullShipWithPilot then (readtext.{98765}.{200} + '\n' + (if $Ships.count gt 1 then readtext.{98765}.{403} else readtext.{98765}.{402})) else readtext.{98765}.{200})" />
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_unassign_pilot',
                $section  = $s_other,
                $text     = readtext.{98765}.{2},
                $mouseover = $UnassignMouseover,
                $active   = $UnassignActive,
                $callback = SCM_unassign_callback,
                ]" />
  
            <!-- 3.3 Fire Captain -->
            <set_value name="$FireActive" exact="$HasAnyPilot" />
            <set_value name="$FireMouseover" exact="if not $FireActive then readtext.{98765}.{404} else readtext.{98765}.{201}" />
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_fire_pilot',
                $section  = $s_other,
                $text     = readtext.{98765}.{3},
                $mouseover = $FireMouseover,
                $active   = $FireActive,
                $callback = SCM_fire_callback,
                ]" />

            <!-- 3.4 Drop Cargo (original text: id="8") -->
            <set_value name="$DropCargoActive" exact="false" />
            <do_all exact="$Ships.count" counter="$i">
              <do_if value="$Ships.{$i}.cargo.count gt 0">
                <set_value name="$DropCargoActive" exact="true" />
              </do_if>
            </do_all>
            <set_value name="$DropCargoMouseover" exact="if not $DropCargoActive then readtext.{98765}.{406} else readtext.{98765}.{203}" />
            <signal_cue_instantly
              cue="md.Interact_Menu_API.Add_Action"
              param="table[
                $id       = 'scm_drop_cargo',
                $section  = $s_other,
                $text     = readtext.{98765}.{5},
                $mouseover = $DropCargoMouseover,
                $active   = $DropCargoActive,
                $callback = SCM_drop_cargo_callback,
                ]" />
          </do_if>
        </do_if>
      </actions>
    </cue>


    <!-- ============================================================
         2. Batch Dismiss Captain Callback
         - Empty the pilot slot only (NPC remains on the ship as unassigned crew)
         ============================================================ -->
    <cue name="SCM_unassign_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- Build list of selected ships -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Unassign start: ' + $Ships.count + ' ships'" filter="general" />

        <do_if value="$Ships.count gt 0">
        <set_value name="$SuccessCount" exact="0" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            <set_value name="$WorstCrew" exact="null" />
            <set_value name="$WorstSkill" exact="9999" />
            
            <!-- Prevent crew capacity overflow: If no free slot, auto-fire the lowest skilled crew member -->
            <do_if value="$Ship.people.free le 0">
              <set_value name="$CrewList" exact="$Ship.people.list" />
              <do_all exact="$CrewList.count" counter="$k">
                <set_value name="$Template" exact="$CrewList.{$k}" />
                <set_value name="$Role" exact="$Ship.people.{$Template}.role" />
                <do_if value="$Role != entityrole.pilot and $Template != @$Pilot.npctemplate">
                  <set_value name="$Morale" exact="$Ship.people.{$Template}.skill.morale" />
                  <set_value name="$PrimarySkill" exact="0" />
                  
                  <!-- Identify primary skill based on role (Service Crew: Engineering, Marine: Boarding) -->
                  <do_if value="$Role == entityrole.service">
                    <set_value name="$PrimarySkill" exact="$Ship.people.{$Template}.skill.engineering" />
                  </do_if>
                  <do_elseif value="$Role == entityrole.marine">
                    <set_value name="$PrimarySkill" exact="$Ship.people.{$Template}.skill.boarding" />
                  </do_elseif>
                  <do_else>
                    <!-- If unassigned or other role, assume their highest basic skill is the primary skill -->
                    <set_value name="$MaxBase" exact="0" />
                    <set_value name="$MaxBase" exact="[
                      $Ship.people.{$Template}.skill.piloting,
                      $Ship.people.{$Template}.skill.engineering,
                      $Ship.people.{$Template}.skill.boarding,
                      $Ship.people.{$Template}.skill.management
                    ].max" />
                    <set_value name="$PrimarySkill" exact="$MaxBase" />
                  </do_else>
                  
                  <!-- Vanilla combined skill formula: (primary_skill * 3 + morale) / 4 -->
                  <set_value name="$EffectiveSkillVal" exact="($PrimarySkill * 3) + $Morale" />
                  
                  <do_if value="$EffectiveSkillVal lt $WorstSkill">
                    <set_value name="$WorstSkill" exact="$EffectiveSkillVal" />
                    <set_value name="$WorstCrew" exact="$Template" />
                    <set_value name="$WorstCrewRole" exact="$Role" />
                    <set_value name="$WorstCrewStars" exact="$PrimarySkill / 3" />
                  </do_if>
                </do_if>
              </do_all>
              <do_if value="$WorstCrew">
                <set_value name="$WorstCrewName" exact="$Ship.people.{$WorstCrew}.name" />
                <debug_text text="'[SCM] Ship full. Firing worst crew ' + $WorstCrewName + ' (score: ' + $WorstSkill + ') to make space for dismissed pilot.'" filter="general" />
                <remove_npc_template object="$Ship" template="$WorstCrew" />
              </do_if>
            </do_if>

            <set_value name="$Template" exact="@$Pilot.npctemplate" />
            <set_value name="$PilotExists" exact="$Pilot.exists" />
            
            <debug_text text="'[SCM] Unassigning pilot for: ' + $Ship.knownname + ' | pilot_name=' + $Pilot.knownname + ' | pilot_exists=' + $PilotExists + ' | template=' + $Template" filter="general" />
            
            <!-- Dismiss pilot -->
            <dismiss_control_entity actor="$Pilot" object="$Ship" />
            
            <!-- Change NPC entity role (Unassigned status) -->
            <do_if value="$PilotExists">
              <set_entity_role entity="$Pilot" role="entityrole.unassigned" />
              <set_entity_role_object entity="$Pilot" object="$Ship" />
            </do_if>
            
            <!-- Change NPC template role -->
            <do_if value="$Template">
              <do_if value="$Ship.people.{$Template}.exists">
                <set_npc_template_role object="$Ship" template="$Template" role="entityrole.unassigned" />
              </do_if>
              <do_else>
                <create_npc_template object="$Ship" entity="$Pilot" role="entityrole.unassigned" />
              </do_else>
            </do_if>
            <do_else>
              <debug_text text="'[SCM] Warning: No npctemplate found for pilot!'" filter="general" />
            </do_else>
            
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{303}.[$Ship.knownname, ($Pilot.skill.piloting / 3), $Pilot.knownname]" />
            <set_value name="$SuccessCount" exact="$SuccessCount + 1" />
          </do_if>
        </do_all>

        <do_if value="$SuccessCount gt 0">
          <show_notification text="readtext.{98765}.{300}.[$SuccessCount]" timeout="6s" />
        </do_if>
      </do_if>
      </actions>
    </cue>


    <!-- ============================================================
         3. Batch Fire Captain Callback
         - Empty the pilot slot and destroy the NPC entity
         ============================================================ -->
    <cue name="SCM_fire_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- Build list of selected ships -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Fire start: ' + $Ships.count + ' ships'" filter="general" />

        <do_if value="$Ships.count gt 0">
        <set_value name="$SuccessCount" exact="0" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            <set_value name="$PilotName" exact="$Pilot.knownname" />
            <set_value name="$PilotPiloting" exact="$Pilot.skill.piloting" />
            <debug_text text="'[SCM] Firing: ' + $PilotName + ' from ' + $Ship.knownname" filter="general" />
            
            <!-- Dismiss and destroy pilot entity (to prevent references getting stuck) -->
            <dismiss_control_entity actor="$Pilot" object="$Ship" />
            <destroy_object object="$Pilot" />
            
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{304}.[$Ship.knownname, ($PilotPiloting / 3), $PilotName]" />
            <set_value name="$SuccessCount" exact="$SuccessCount + 1" />
          </do_if>
        </do_all>

        <do_if value="$SuccessCount gt 0">
          <show_notification text="readtext.{98765}.{302}.[$SuccessCount]" timeout="6s" sound="notification_warning" />
        </do_if>
      </do_if>
      </actions>
    </cue>


    <!-- ============================================================
         4. Batch Assign Captain Callback
         - Find the best unassigned crew member with the highest piloting skill from player-owned ships galaxy-wide
         - Sort target ships by 16 priority classes (XL > L > M > S and fight > trade > mine > build)
         ============================================================ -->
    <cue name="SCM_assign_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- Build list of selected ships -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <do_if value="$Ships.count gt 0">
        <!-- Identify minimum/maximum skill limits based on action ID -->
        <set_value name="$ActionId" exact="event.param.$id" />
        <set_value name="$MinSkill" exact="-1" />
        <set_value name="$MaxSkill" exact="9999" />
        
        <do_if value="$ActionId == 'scm_assign_5star'">
          <set_value name="$MinSkill" exact="15" />
          <set_value name="$MaxSkill" exact="16" /><!-- Explicit upper bound: vanilla 5-star max is 15 -->
        </do_if>
        <do_elseif value="$ActionId == 'scm_assign_4star'">
          <set_value name="$MinSkill" exact="12" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_3star'">
          <set_value name="$MinSkill" exact="9" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_2star'">
          <set_value name="$MinSkill" exact="6" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_1star'">
          <set_value name="$MinSkill" exact="3" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_under_5star'">
          <set_value name="$MaxSkill" exact="15" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_under_4star'">
          <set_value name="$MaxSkill" exact="12" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_under_3star'">
          <set_value name="$MaxSkill" exact="9" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_rookie'">
          <set_value name="$MaxSkill" exact="6" />
        </do_elseif>
        <do_elseif value="$ActionId == 'scm_assign_under_1star'">
          <set_value name="$MaxSkill" exact="3" />
        </do_elseif>

        <create_list name="$TargetShips" />
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="not @$Ship.pilot">
            <append_to_list name="$TargetShips" exact="$Ship" />
          </do_if>
        </do_all>

        <do_if value="$TargetShips.count gt 0">
          <!-- Create split lists to sort by Priority 1: Class (XL > L > M > S) and Priority 2: Category (Combat > Civilian) -->
          <create_list name="$Ships_XL" />
          <create_list name="$Ships_L" />
          <create_list name="$Ships_M" />
          <create_list name="$Ships_S" />

          <do_all exact="$TargetShips.count" counter="$i">
            <set_value name="$Ship" exact="$TargetShips.{$i}" />
            <do_if value="$Ship.isclass.ship_xl">
              <append_to_list name="$Ships_XL" exact="$Ship" />
            </do_if>
            <do_elseif value="$Ship.isclass.ship_l">
              <append_to_list name="$Ships_L" exact="$Ship" />
            </do_elseif>
            <do_elseif value="$Ship.isclass.ship_m">
              <append_to_list name="$Ships_M" exact="$Ship" />
            </do_elseif>
            <do_elseif value="$Ship.isclass.ship_s">
              <append_to_list name="$Ships_S" exact="$Ship" />
            </do_elseif>
          </do_all>

          <create_list name="$SortedShips" />

          <!-- Define ship purpose priority list (fight > trade > mine > build) -->
          <create_list name="$Purposes" />
          <append_to_list name="$Purposes" exact="purpose.fight" />
          <append_to_list name="$Purposes" exact="purpose.trade" />
          <append_to_list name="$Purposes" exact="purpose.mine" />
          <append_to_list name="$Purposes" exact="purpose.build" />

          <!-- Collection of class lists for sorting loop -->
          <create_list name="$ClassLists" />
          <append_to_list name="$ClassLists" exact="$Ships_XL" />
          <append_to_list name="$ClassLists" exact="$Ships_L" />
          <append_to_list name="$ClassLists" exact="$Ships_M" />
          <append_to_list name="$ClassLists" exact="$Ships_S" />

          <!-- Iterate by class (XL -> L -> M -> S) and sort by purpose -->
          <do_all exact="$ClassLists.count" counter="$c">
            <set_value name="$CurrentClassList" exact="$ClassLists.{$c}" />

            <!-- Step 1: Merge according to defined purposes -->
            <do_all exact="$Purposes.count" counter="$p">
              <set_value name="$CurrentPurpose" exact="$Purposes.{$p}" />
              <do_all exact="$CurrentClassList.count" counter="$i">
                <set_value name="$Ship" exact="$CurrentClassList.{$i}" />
                <do_if value="$Ship.primarypurpose == $CurrentPurpose">
                  <append_to_list name="$SortedShips" exact="$Ship" />
                </do_if>
              </do_all>
            </do_all>

            <!-- Step 2: Append ships with other (miscellaneous) purposes -->
            <do_all exact="$CurrentClassList.count" counter="$i">
              <set_value name="$Ship" exact="$CurrentClassList.{$i}" />
              <do_if value="not $Purposes.indexof.{$Ship.primarypurpose}">
                <append_to_list name="$SortedShips" exact="$Ship" />
              </do_if>
            </do_all>
          </do_all>

          <debug_text text="'[SCM] Sorted target ships count: ' + $SortedShips.count" filter="general" />

          <!-- List of all player-owned ships and stations (for candidate search) -->
          <find_ship name="$PlayerShips" owner="faction.player" multiple="true" space="player.galaxy" recursive="true" />
          <find_station name="$PlayerStations" owner="faction.player" multiple="true" space="player.galaxy" />

          <create_list name="$AllSources" />
          <do_all exact="$PlayerShips.count" counter="$s">
            <append_to_list name="$AllSources" exact="$PlayerShips.{$s}" />
          </do_all>
          <do_all exact="$PlayerStations.count" counter="$s">
            <append_to_list name="$AllSources" exact="$PlayerStations.{$s}" />
          </do_all>

          <!-- Create unified candidates cache to scan galaxy-wide unassigned crew only once -->
          <create_list name="$CandidateList" />
          <do_all exact="$AllSources.count" counter="$j">
            <set_value name="$PSource" exact="$AllSources.{$j}" />
            <set_value name="$SourcePeople" exact="$PSource.people.list" />
            <do_all exact="$SourcePeople.count" counter="$k">
              <set_value name="$Template" exact="$SourcePeople.{$k}" />
              <set_value name="$Role" exact="$PSource.people.{$Template}.role" />
              <set_value name="$Seed" exact="@$PSource.people.{$Template}.seed" />
              <set_value name="$NPC_Piloting" exact="$PSource.people.{$Template}.skill.{skilltype.piloting}" />
              <do_if value="$Role == entityrole.unassigned and $NPC_Piloting ge $MinSkill and $NPC_Piloting lt $MaxSkill">
                <append_to_list name="$CandidateList" exact="table[$template = $Template, $source = $PSource, $seed = $Seed, $piloting = $NPC_Piloting]" />
              </do_if>
            </do_all>
          </do_all>
          <debug_text text="'[SCM] Galaxy-wide unassigned candidates cached: ' + $CandidateList.count" filter="general" />

          <!-- Lists to prevent duplicate assignments -->
          <create_list name="$AssignedCandidates" />
          <create_list name="$AssignedSeeds" />

          <!-- Now iterate through the sorted ships list and assign captains -->
          <do_all exact="$SortedShips.count" counter="$i">
            <set_value name="$Ship" exact="$SortedShips.{$i}" />

            <set_value name="$BestCandidateIdx" exact="0" />
            <set_value name="$BestPiloting" exact="-1" />

            <!-- Find the candidate with the highest piloting skill in our cached list -->
            <!-- Priority 1: Highest piloting skill (primary) -->
            <!-- Priority 2: Current ship local crew (tie-breaker to avoid unnecessary relocation) -->
            <do_all exact="$CandidateList.count" counter="$idx">
              <set_value name="$Cand" exact="$CandidateList.{$idx}" />
              <set_value name="$Score" exact="$Cand.$piloting * 10" />
              <do_if value="$Cand.$source == $Ship">
                <set_value name="$Score" exact="$Score + 1" />
              </do_if>
              
              <do_if value="$Score gt $BestPiloting">
                <set_value name="$BestPiloting" exact="$Score" />
                <set_value name="$BestCandidateIdx" exact="$idx" />
              </do_if>
            </do_all>

            <do_if value="$BestCandidateIdx gt 0">
              <set_value name="$BestCandTable" exact="$CandidateList.{$BestCandidateIdx}" />
              <set_value name="$BestCandidate" exact="$BestCandTable.$template" />
              <set_value name="$BestSource" exact="$BestCandTable.$source" />
              <set_value name="$BestSeed" exact="$BestCandTable.$seed" />
              <set_value name="$RealPiloting" exact="$BestCandTable.$piloting" />
              
              <!-- Pop selected candidate from cache -->
              <remove_from_list name="$CandidateList" exact="$BestCandTable" />

              <!-- Check if the template already has an active NPC entity -->
              <set_value name="$TargetActor" exact="$BestSource.roleentity.{$BestCandidate}" />

              <do_if value="not $TargetActor">
                <!-- No active entity; instantiate NPC from template -->
                <create_npc_from_template name="$TargetActor" object="$BestSource" template="$BestCandidate" owner="faction.player" placementobject="$Ship" required="false" />
              </do_if>

              <do_if value="$TargetActor">
                <debug_text text="'[SCM] Assigning ' + $TargetActor.knownname + ' (skill ' + $RealPiloting + ') to ' + $Ship.knownname" filter="general" />
                <assign_control_entity actor="$TargetActor" object="$Ship" post="controlpost.aipilot" transfer="true" init="true" />
                
                <!-- Add selected template and seed to lists to prevent double assignment -->
                <append_to_list name="$AssignedCandidates" exact="$BestCandidate" />
                <do_if value="$BestSeed gt 0">
                  <append_to_list name="$AssignedSeeds" exact="$BestSeed" />
                </do_if>

                <!-- Template transferred; remove template from the source ship -->
                <do_if value="$BestSource.people.{$BestCandidate}.exists">
                  <remove_npc_template object="$BestSource" template="$BestCandidate" />
                </do_if>

                <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{305}.[$Ship.knownname, ($RealPiloting / 3), $TargetActor.knownname]" />
              </do_if>
              <do_else>
                <debug_text text="'[SCM] Failed to instantiate candidate: ' + $BestCandidate + ' for ' + $Ship.knownname" filter="general" />
              </do_else>
            </do_if>
            <do_else>
              <debug_text text="'[SCM] Failed to find candidate for ' + $Ship.knownname" filter="general" />
            </do_else>
          </do_all>

          <!-- Report results -->
          <do_if value="$AssignedCandidates.count gt 0">
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{301}.[$AssignedCandidates.count]" />
            <show_notification text="readtext.{98765}.{301}.[$AssignedCandidates.count]" timeout="6s" />
          </do_if>


        </do_if>
        </do_if>
      </actions>
    </cue>

    <!-- ============================================================
         5. Batch Transfer Unassigned Crew Callback
         - Find all unassigned crew members from all player-owned ships and stations
         - Sort them by (highest_skill * 3 + morale) and transfer the best crew members to fill the target ship
         ============================================================ -->
    <cue name="SCM_fill_unassigned_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <set_value name="$Ship" exact="event.param.$object" />
        <do_if value="(@$Ship.isclass.ship or @$Ship.isclass.station) and $Ship.isplayerowned">
          <set_value name="$FreeSlots" exact="$Ship.people.free" />
          <do_if value="$FreeSlots gt 0">
            <set_value name="$MinSkill" exact="-1" />
            <set_value name="$MaxSkill" exact="9999" />

            <!-- 1. Find player-owned ships and stations -->
            <find_ship name="$PlayerShips" owner="faction.player" multiple="true" space="player.galaxy" recursive="true" />
            <find_station name="$PlayerStations" owner="faction.player" multiple="true" space="player.galaxy" />

            <create_list name="$AllSources" />
            <do_all exact="$PlayerShips.count" counter="$s">
              <append_to_list name="$AllSources" exact="$PlayerShips.{$s}" />
            </do_all>
            <do_all exact="$PlayerStations.count" counter="$s">
              <append_to_list name="$AllSources" exact="$PlayerStations.{$s}" />
            </do_all>

            <!-- 2. Collect unassigned candidates -->
            <create_list name="$Candidates" />
            <do_all exact="$AllSources.count" counter="$s">
              <set_value name="$Source" exact="$AllSources.{$s}" />
              <!-- Exclude the target ship itself -->
              <do_if value="$Source != $Ship">
                <set_value name="$People" exact="$Source.people.list" />
                <do_all exact="$People.count" counter="$p">
                  <set_value name="$Template" exact="$People.{$p}" />
                  <set_value name="$Role" exact="$Source.people.{$Template}.role" />
                  <do_if value="$Role == entityrole.unassigned">
                    <!-- Calculate skill score (max_of_4_basic_skills * 3 + morale) -->
                    <set_value name="$MaxBase" exact="0" />
                    <set_value name="$MaxBase" exact="[
                      $Source.people.{$Template}.skill.piloting,
                      $Source.people.{$Template}.skill.engineering,
                      $Source.people.{$Template}.skill.boarding,
                      $Source.people.{$Template}.skill.management
                    ].max" />
                    
                    <!-- Filter based on skill criteria -->
                    <do_if value="$MaxBase ge $MinSkill and $MaxBase lt $MaxSkill">
                      <set_value name="$Morale" exact="$Source.people.{$Template}.skill.morale" />
                      <set_value name="$Score" exact="($MaxBase * 3) + $Morale" />

                      <append_to_list name="$Candidates" exact="table[
                        $source = $Source,
                        $template = $Template,
                        $score = $Score
                      ]" />
                    </do_if>
                  </do_if>
                </do_all>
              </do_if>
            </do_all>

            <debug_text text="'[SCM] Found ' + $Candidates.count + ' unassigned candidates. Capacity left: ' + $FreeSlots" filter="general" />

            <do_if value="$Candidates.count gt 0">
              <!-- 3. Select the highest scoring crew members up to $FreeSlots -->
              <set_value name="$TotalCandidatesCount" exact="$Candidates.count" />
              <create_list name="$SelectedCandidates" />
              <set_value name="$LoopCount" exact="if $FreeSlots lt $Candidates.count then $FreeSlots else $Candidates.count" />

              <do_all exact="$LoopCount">
                <set_value name="$BestEntry" exact="null" />
                <set_value name="$BestScore" exact="-1" />
                <do_all exact="$Candidates.count" counter="$idx">
                  <do_if value="$Candidates.{$idx}.$score gt $BestScore">
                    <set_value name="$BestScore" exact="$Candidates.{$idx}.$score" />
                    <set_value name="$BestEntry" exact="$Candidates.{$idx}" />
                  </do_if>
                </do_all>
                <!-- Use entry reference directly to avoid stale index after list shrinks -->
                <do_if value="$BestEntry">
                  <append_to_list name="$SelectedCandidates" exact="$BestEntry" />
                  <remove_from_list name="$Candidates" exact="$BestEntry" />
                </do_if>
              </do_all>

              <!-- 4. Group by source object and transfer -->
              <create_list name="$UniqueSources" />
              <do_all exact="$SelectedCandidates.count" counter="$i">
                <set_value name="$Src" exact="$SelectedCandidates.{$i}.$source" />
                <do_if value="not $UniqueSources.indexof.{$Src}">
                  <append_to_list name="$UniqueSources" exact="$Src" />
                </do_if>
              </do_all>

              <set_value name="$TotalTransferred" exact="0" />
              <do_all exact="$UniqueSources.count" counter="$s">
                <set_value name="$Src" exact="$UniqueSources.{$s}" />
                <create_list name="$LocalTemplates" />
                <do_all exact="$SelectedCandidates.count" counter="$i">
                  <do_if value="$SelectedCandidates.{$i}.$source == $Src">
                    <append_to_list name="$LocalTemplates" exact="$SelectedCandidates.{$i}.$template" />
                  </do_if>
                </do_all>

                <do_if value="$LocalTemplates.count gt 0">
                  <debug_text text="'[SCM] Transferring ' + $LocalTemplates.count + ' templates from ' + $Src.knownname + ' to ' + $Ship.knownname" filter="general" />
                  <transfer_people object="$Ship" otherobject="$Src" result="$Transferred" force="true">
                    <existing_people people="$LocalTemplates" />
                  </transfer_people>
                  <set_value name="$TotalTransferred" exact="$TotalTransferred + $Transferred.count" />
                </do_if>
              </do_all>

              <!-- 5. Write to logbook and show notification -->
              <do_if value="$TotalTransferred gt 0">
                <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{306}.[$Ship.knownname, $TotalTransferred]" />
                <show_notification text="readtext.{98765}.{306}.[$Ship.knownname, $TotalTransferred]" timeout="6s" />
              </do_if>
            </do_if>
          </do_if>
        </do_if>
      </actions>
    </cue>

    <!-- ============================================================
         6. Batch Use Seminars Callback
         - Check piloting skill of captains on selected ships
         - Check inventory for required piloting seminars, consume, and raise skill
         ============================================================ -->
    <cue name="SCM_use_seminar_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- Build list of selected ships -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <set_value name="$SuccessCount" exact="0" />
        <set_value name="$Used_0" exact="0" />
        <set_value name="$Used_1" exact="0" />
        <set_value name="$Used_2" exact="0" />
        <set_value name="$Used_3" exact="0" />
        <set_value name="$Used_4" exact="0" />

        <set_value name="$ActionId" exact="event.param.$id" />

        <do_if value="$Ships.count gt 0">
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="@$Ship.pilot">
            <set_value name="$Pilot" exact="$Ship.pilot" />
            
            <set_value name="$LoopEnded" exact="false" />
            <!-- Max 5 upgrades can happen per pilot -->
            <do_all exact="5">
              <do_if value="not $LoopEnded">
                <set_value name="$Piloting" exact="$Pilot.skill.piloting" />
                <set_value name="$TargetSeminar" exact="null" />
                <set_value name="$SeminarIndex" exact="-1" />
                <set_value name="$TargetSkillVal" exact="if ($Piloting + 3) gt 15 then 15 else ($Piloting + 3)" />

                <!-- Apply vanilla seminar mapping rules (5 tiers) -->
                <do_if value="$Piloting lt 3">
                  <!-- Under 1-star -> Basic piloting seminar -->
                  <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_0" />
                  <set_value name="$SeminarIndex" exact="0" />
                </do_if>
                <do_elseif value="$Piloting ge 3 and $Piloting lt 6">
                  <!-- 1-star range -> 1-star piloting seminar -->
                  <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_1" />
                  <set_value name="$SeminarIndex" exact="1" />
                </do_elseif>
                <do_elseif value="$Piloting ge 6 and $Piloting lt 9">
                  <!-- 2-star range -> 2-star piloting seminar -->
                  <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_2" />
                  <set_value name="$SeminarIndex" exact="2" />
                </do_elseif>
                <do_elseif value="$Piloting ge 9 and $Piloting lt 12">
                  <!-- 3-star range -> 3-star piloting seminar -->
                  <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_3" />
                  <set_value name="$SeminarIndex" exact="3" />
                </do_elseif>
                <do_elseif value="$Piloting ge 12 and $Piloting lt 15">
                  <!-- 4-star range -> 4-star piloting seminar -->
                  <set_value name="$TargetSeminar" exact="ware.inv_seminar_piloting_4" />
                  <set_value name="$SeminarIndex" exact="4" />
                </do_elseif>

                <!-- Check maximum skill limit based on ActionId -->
                <set_value name="$LimitPass" exact="false" />
                <do_if value="$TargetSeminar != null">
                  <do_if value="$ActionId == 'scm_seminar_max' or $ActionId == 'scm_seminar_5star'">
                    <set_value name="$LimitPass" exact="true" />
                  </do_if>
                  <do_elseif value="$ActionId == 'scm_seminar_4star' and $Piloting lt 12">
                    <set_value name="$LimitPass" exact="true" />
                  </do_elseif>
                  <do_elseif value="$ActionId == 'scm_seminar_3star' and $Piloting lt 9">
                    <set_value name="$LimitPass" exact="true" />
                  </do_elseif>
                  <do_elseif value="$ActionId == 'scm_seminar_2star' and $Piloting lt 6">
                    <set_value name="$LimitPass" exact="true" />
                  </do_elseif>
                  <do_elseif value="$ActionId == 'scm_seminar_1star' and $Piloting lt 3">
                    <set_value name="$LimitPass" exact="true" />
                  </do_elseif>
                  <do_elseif value="$ActionId == 'scm_seminar_single'">
                    <set_value name="$LimitPass" exact="true" />
                  </do_elseif>
                </do_if>

                <!-- Check if the seminar exists in player inventory and consume it -->
                <do_if value="$LimitPass and player.entity.inventory.{$TargetSeminar}.count gt 0">
                  <remove_inventory entity="player.entity" ware="$TargetSeminar" exact="1" />
                  <set_skill entity="$Pilot" type="skilltype.piloting" exact="$TargetSkillVal" />
                  
                  <set_value name="$SuccessCount" exact="$SuccessCount + 1" />
                  
                  <do_if value="$SeminarIndex == 0">
                    <set_value name="$Used_0" exact="$Used_0 + 1" />
                  </do_if>
                  <do_if value="$SeminarIndex == 1">
                    <set_value name="$Used_1" exact="$Used_1 + 1" />
                  </do_if>
                  <do_if value="$SeminarIndex == 2">
                    <set_value name="$Used_2" exact="$Used_2 + 1" />
                  </do_if>
                  <do_if value="$SeminarIndex == 3">
                    <set_value name="$Used_3" exact="$Used_3 + 1" />
                  </do_if>
                  <do_if value="$SeminarIndex == 4">
                    <set_value name="$Used_4" exact="$Used_4 + 1" />
                  </do_if>
                  
                  <!-- If only single training mode, break loop immediately -->
                  <do_if value="$ActionId == 'scm_seminar_single'">
                    <set_value name="$LoopEnded" exact="true" />
                  </do_if>
                </do_if>
                <do_else>
                  <!-- No available seminar or limit reached -> stop continuous training for this captain -->
                  <set_value name="$LoopEnded" exact="true" />
                </do_else>
              </do_if>
            </do_all>
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Use Seminar finished. Promoted ' + $SuccessCount + ' captains'" filter="general" />

        <!-- Show feedback and notify player -->
        <do_if value="$SuccessCount gt 0">
          <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{307}.[$SuccessCount, $Used_0, $Used_1, $Used_2, $Used_3, $Used_4]" />
          <show_notification text="readtext.{98765}.{307}.[$SuccessCount, $Used_0, $Used_1, $Used_2, $Used_3, $Used_4]" timeout="6s" />
        </do_if>
      </do_if>
      </actions>
    </cue>

    <!-- ============================================================
         7. Batch Drop Cargo Callback
         - Eject all container/cargo items of selected ships into space
         ============================================================ -->
    <cue name="SCM_drop_cargo_callback" instantiate="true">
      <conditions>
        <event_cue_signalled />
      </conditions>
      <actions>
        <!-- Build list of selected ships -->
        <create_list name="$Ships" />
        <do_if value="@event.param.$object.isclass.ship and event.param.$object.isplayerowned">
          <append_to_list name="$Ships" exact="event.param.$object" />
        </do_if>
        <do_all exact="@event.param.$selectedplayerships.count" counter="$i">
          <set_value name="$SelShip" exact="event.param.$selectedplayerships.{$i}" />
          <do_if value="not $Ships.indexof.{$SelShip}">
            <append_to_list name="$Ships" exact="$SelShip" />
          </do_if>
        </do_all>

        <debug_text text="'[SCM] Drop Cargo start: ' + $Ships.count + ' ships'" filter="general" />
        <do_if value="$Ships.count gt 0">
        <do_all exact="$Ships.count" counter="$i">
          <set_value name="$Ship" exact="$Ships.{$i}" />
          <do_if value="$Ship.cargo.count gt 0">
            <set_value name="$CargoList" exact="$Ship.cargo.list" />
            <set_value name="$WaresCount" exact="$CargoList.count" />
            
            <!-- Loop through each ware in cargo and drop its entire count -->
            <do_all exact="$WaresCount" counter="$k">
              <set_value name="$Ware" exact="$CargoList.{$k}" />
              <set_value name="$Amount" exact="$Ship.cargo.{$Ware}.count" />
              <do_if value="$Amount gt 0">
                <debug_text text="'[SCM] Dropping ' + $Amount + ' of ' + $Ware + ' from ' + $Ship.knownname" filter="general" />
                <drop_cargo object="$Ship" ware="$Ware" exact="$Amount" />
              </do_if>
            </do_all>
            
            <!-- Output success to logbook and show notification -->
            <write_to_logbook category="tips" title="readtext.{98765}.{1}" text="readtext.{98765}.{308}.[$Ship.knownname, $WaresCount]" />
            <show_notification text="readtext.{98765}.{308}.[$Ship.knownname, $WaresCount]" timeout="6s" />
          </do_if>
        </do_all>
      </do_if>
      </actions>
    </cue>

  </cues>
</mdscript>
<?xml version="1.0" encoding="UTF-8"?>
<language id="7"> <!-- Russian -->
  <page id="98765" title="Simple Captain Manager Texts">
    <!-- Category A: Main UI & Common Buttons (ID: 1 ~ 9) -->
    <t id="1">Управление капитанами</t>
    <t id="2">Снять капитана с должности</t>
    <t id="3">Уволить капитана</t>
    <t id="4">Переместить незанятый экипаж</t>
    <t id="5">Сбросить груз</t>
    <!-- Category B: Submenu Groups & Function Names (ID: 10 ~ 19) -->
    <t id="10">Назначить капитана</t>
    <t id="11">Использовать семинары</t>
    <t id="12">Прочие функции капитана</t>
    <!-- Category C: Auto Assign Button Names (ID: 100 ~ 119) -->
    <t id="100">Назначить весь свободный персонал</t>
    <t id="101">Только 5-зв. навык</t>
    <t id="102">Только 4-зв. и выше</t>
    <t id="103">Только 3-зв. и выше</t>
    <t id="104">Только 2-зв. и выше</t>
    <t id="105">Только 1-зв. и выше</t>
    <t id="106">Только ниже 5-зв.</t>
    <t id="107">Только ниже 4-зв.</t>
    <t id="108">Только ниже 3-зв.</t>
    <t id="109">Только ниже 2-зв.</t>
    <t id="110">Только ниже 1-зв.</t>
    <!-- Category D: Seminar Training Button Names (ID: 120 ~ 129) -->
    <t id="120">До максимального уровня [все семинары последовательно]</t>
    <t id="121">Обучить до 5 звезд</t>
    <t id="122">До 4-зв. [семинары до 3-зв.]</t>
    <t id="123">До 3-зв. [семинары до 2-зв.]</t>
    <t id="124">До 2-зв. [семинары до 1-зв.]</t>
    <t id="125">До 1-зв. [базовые семинары]</t>
    <t id="126">Только 1 семинар</t>
    <!-- Category E: UI Function Description Tooltips (ID: 200 ~ 249) -->
    <t id="200">Снимает капитана с должности и переводит в резерв экипажа.</t>
    <t id="201">Немедленно увольняет капитана.</t>
    <t id="202">Перемещает незакреплённых членов экипажа для заполнения корабля согласно приоритету.</t>
    <t id="203">Сбрасывает весь груз в космос.</t>
    <t id="204">Выбирает и назначает только незакреплённых членов экипажа с навыком пилотирования 5 звёзд.</t>
    <t id="205">Назначает свободный персонал по всей галактике в порядке наивысшего уровня навыков.</t>
    <t id="206">Выбирает и назначает незакреплённых с навыком пилотирования 3-зв. или выше.</t>
    <t id="207">Выбирает и назначает незакреплённых с навыком пилотирования 2-зв. или выше.</t>
    <t id="208">Выбирает и назначает незакреплённых с навыком пилотирования ниже 2-зв..</t>
    <t id="209">Выбирает и назначает незакреплённых с навыком пилотирования 4-зв. или выше.</t>
    <t id="210">Выбирает и назначает незакреплённых с навыком пилотирования 1-зв. или выше.</t>
    <t id="211">Выбирает и назначает незакреплённых с навыком пилотирования ниже 5-зв..</t>
    <t id="212">Выбирает и назначает незакреплённых с навыком пилотирования ниже 4-зв..</t>
    <t id="213">Выбирает и назначает незакреплённых с навыком пилотирования ниже 3-зв..</t>
    <t id="214">Выбирает и назначает незакреплённых с навыком пилотирования ниже 1-зв..</t>
    <t id="215">Последовательно использует все имеющиеся семинары для достижения 5-зв. навыка.</t>
    <t id="216">Использует семинары от базовых до 3-зв. для достижения 4-зв. навыка.</t>
    <t id="217">Использует семинары от базовых до 2-зв. для достижения 3-зв. навыка.</t>
    <t id="218">Использует 1 семинар подходящего уровня для повышения навыка на 1 ступень.</t>
    <t id="219">Использует семинары от базовых до 1-зв. для достижения 2-зв. навыка.</t>
    <t id="220">Использует базовые семинары для достижения 1-зв. навыка.</t>
    <t id="221">Последовательно расходует семинары от базового до 4-звездочного для обучения навыку пилотирования до 5 звезд.</t>
    <!-- Category F: Unassigned Pilot Statistics Tooltips (ID: 250 ~ 269) -->
    <t id="250">Всего свободных пилотов: %1</t>
    <t id="251">Пилотов с 5 звездами: %1</t>
    <t id="252">Пилотов с 4 звездами и выше: %1</t>
    <t id="253">Пилотов с 3 звездами и выше: %1</t>
    <t id="254">Пилотов с 2 звездами и выше: %1</t>
    <t id="255">Пилотов с 1 звездой и выше: %1</t>
    <t id="256">Пилотов с менее чем 5 звездами: %1</t>
    <t id="257">Пилотов с менее чем 4 звездами: %1</t>
    <t id="258">Пилотов с менее чем 3 звездами: %1</t>
    <t id="259">Пилотов с менее чем 2 звездами: %1</t>
    <t id="260">Пилотов с менее чем 1 звездой: %1</t>
    <!-- Category G: Action Logbook & Notification Messages (ID: 300 ~ 399) -->
    <t id="300">Капитанов: %1 переведено в резерв.</t>
    <t id="301">На %1 кор. назначены капитаны.</t>
    <t id="302">Уволено капитанов: %1.</t>
    <t id="303">Капитан [%3] с навыком %2 зв. корабля %1 снят с должности и переведен в резерв.</t>
    <t id="304">Капитан [%3] с навыком %2 зв. корабля %1 уволен.</t>
    <t id="305">На корабль %1 назначен капитан [%3] с навыком %2 зв.</t>
    <t id="306">Переведено %2 свободных членов экипажа на %1.</t>
    <t id="307">Обучение завершено: повышены %1 кап. [Использовано семинаров: базовых: %2, 1-зв: %3, 2-зв: %4, 3-зв: %5, 4-зв: %6]</t>
    <t id="308">Весь груз [%2 видов товаров] корабля %1 был сброшен в космос.</t>
    <!-- Category H: Disabled Warning Tooltips (ID: 400 ~ 499) -->
    <t id="400">Нет капитана для снятия с должности.</t>
    <t id="401">Капитан уже назначен на этот корабль.</t>
    <t id="402">Экипаж корабля заполнен. Чтобы освободить место для уволенного капитана, наименее квалифицированный член экипажа будет автоматически уволен.</t>
    <t id="403">Экипаж некоторых кораблей заполнен. Чтобы освободить место для уволенных капитанов, наименее квалифицированный член экипажа на этих кораблях будет автоматически уволен.</t>
    <t id="404">Нет капитана для увольнения.</t>
    <t id="405">Нет капитанов для обучения.</t>
    <t id="406">Нет груза для сброса.</t>
    <t id="407">На целевом корабле или станции нет свободных мест.</t>
    <t id="408">В вашем инвентаре нет семинаров.</t>
    <t id="409">Недостаточно семинаров для этого обучения. [Не хватает: Базовый x%1]</t>
    <t id="410">Недостаточно семинаров для этого обучения. [Не хватает: Базовый x%1, 1-звездный x%2]</t>
    <t id="411">Недостаточно семинаров для этого обучения. [Не хватает: Базовый x%1, 1-звездный x%2, 2-звездный x%3]</t>
    <t id="412">Недостаточно семинаров для этого обучения. [Не хватает: Базовый x%1, 1-звездный x%2, 2-звездный x%3, 3-звездный x%4]</t>
    <t id="413">Недостаточно семинаров для этого обучения. [Не хватает: Базовый x%1, 1-звездный x%2, 2-звездный x%3, 3-звездный x%4, 4-звездный x%5]</t>
    <t id="414">Недостаточно свободного персонала; капитаны будут назначены только на некоторые корабли.</t>
    <t id="415">Капитаны уже назначены на %1 кораблей; назначения будут произведены только на %2 кораблей.</t>
    <t id="416">Капитаны уже назначены на %1 кораблей, а свободного персонала не хватает; назначения будут произведены только на %2 кораблей.</t>
    <t id="417">Нет доступного свободного персонала.</t>
    <t id="418">Нет доступного свободного 5-звездочного персонала.</t>
    <t id="419">Нет доступного свободного персонала с 4 или более звездами.</t>
    <t id="420">Нет доступного свободного персонала с 3 или более звездами.</t>
    <t id="421">Нет доступного свободного персонала с 2 или более звездами.</t>
    <t id="422">Нет доступного свободного персонала с 1 или более звездами.</t>
    <t id="423">Нет доступного свободного персонала с менее чем 5 звездами.</t>
    <t id="424">Нет доступного свободного персонала с менее чем 4 звездами.</t>
    <t id="425">Нет доступного свободного персонала с менее чем 3 звездами.</t>
    <t id="426">Нет доступного свободного персонала с менее чем 2 звездами.</t>
    <t id="427">Нет доступного свободного персонала с менее чем 1 звездой.</t>
  </page>
</language>
<?xml version="1.0" encoding="UTF-8"?>
<language id="33"> <!-- French -->
  <page id="98765" title="Simple Captain Manager Texts">
    <!-- Category A: Main UI & Common Buttons (ID: 1 ~ 9) -->
    <t id="1">Gestion des capitaines</t>
    <t id="2">Démettre le capitaine</t>
    <t id="3">Licencier le capitaine</t>
    <t id="4">Transférer l'équipage non assigné</t>
    <t id="5">Larguer la cargaison</t>
    <!-- Category B: Submenu Groups & Function Names (ID: 10 ~ 19) -->
    <t id="10">Assigner un capitaine</t>
    <t id="11">Utiliser des séminaires</t>
    <t id="12">Autres fonctions du capitaine</t>
    <!-- Category C: Auto Assign Button Names (ID: 100 ~ 119) -->
    <t id="100">Assigner tout le personnel non assigné</t>
    <t id="101">Compétence 5 étoiles uniquement</t>
    <t id="102">4 étoiles ou plus uniquement</t>
    <t id="103">3 étoiles ou plus uniquement</t>
    <t id="104">2 étoiles ou plus uniquement</t>
