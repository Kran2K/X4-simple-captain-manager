<language id="44"> <!-- English -->
  <page id="98765" title="Simple Captain Manager Texts">
    <!-- Category A: Main UI & Common Buttons (ID: 1 ~ 9) -->
    <t id="1">Simple Captain Manager</t>
    <t id="2">Dismiss Captain</t>
    <t id="3">Fire Captain</t>
    <t id="4">Transfer Unassigned Crew</t>
    <t id="5">Drop Cargo</t>
    <!-- Category B: Submenu Groups & Function Names (ID: 10 ~ 19) -->
    <t id="10">Assign Captain</t>
    <t id="11">Use Seminars</t>
    <t id="12">Other Captain Functions</t>
    <!-- Category C: Auto Assign Button Names (ID: 100 ~ 119) -->
    <t id="100">Assign All Unassigned Crew</t>
    <t id="101">Assign 5-Star only</t>
    <t id="102">Assign 4-Star or higher only</t>
    <t id="103">Assign 3-Star or higher only</t>
    <t id="104">Assign 2-Star or higher only</t>
    <t id="105">Assign 1-Star or higher only</t>
    <t id="106">Assign under 5-Star only</t>
    <t id="107">Assign under 4-Star only</t>
    <t id="108">Assign under 3-Star only</t>
    <t id="109">Assign under 2-Star only</t>
    <t id="110">Assign under 1-Star only</t>
    <!-- Category D: Seminar Training Button Names (ID: 120 ~ 129) -->
    <t id="120">Train to Max Skill [use all seminars sequentially]</t>
    <t id="121">Train to 5-Star</t>
    <t id="122">Train to 4-Star [use up to 3-star seminars]</t>
    <t id="123">Train to 3-Star [use up to 2-star seminars]</t>
    <t id="124">Train to 2-Star [use up to 1-star seminars]</t>
    <t id="125">Train to 1-Star [use basic seminars]</t>
    <t id="126">Use only 1 seminar</t>
    <!-- Category E: UI Function Description Tooltips (ID: 200 ~ 249) -->
    <t id="200">Dismisses the captain and changes their status to unassigned personnel.</t>
    <t id="201">Immediately fires the captain.</t>
    <t id="202">Transfers unassigned crew members to fill the ship according to priority.</t>
    <t id="203">Ejects all cargo into space.</t>
    <t id="204">Selects and assigns only unassigned crew members with a piloting skill of 5-star to the captain slot.</t>
    <t id="205">Appoints unassigned crew galaxy-wide in order of highest skill levels.</t>
    <t id="206">Selects and assigns only unassigned crew members with a piloting skill of 3-star or higher to the captain slot.</t>
    <t id="207">Selects and assigns only unassigned crew members with a piloting skill of 2-star or higher to the captain slot.</t>
    <t id="208">Selects and assigns only unassigned crew members with a piloting skill under 2-star to the captain slot.</t>
    <t id="209">Selects and assigns only unassigned crew members with a piloting skill of 4-star or higher to the captain slot.</t>
    <t id="210">Selects and assigns only unassigned crew members with a piloting skill of 1-star or higher to the captain slot.</t>
    <t id="211">Selects and assigns only unassigned crew members with a piloting skill under 5-star to the captain slot.</t>
    <t id="212">Selects and assigns only unassigned crew members with a piloting skill under 4-star to the captain slot.</t>
    <t id="213">Selects and assigns only unassigned crew members with a piloting skill under 3-star to the captain slot.</t>
    <t id="214">Selects and assigns only unassigned crew members with a piloting skill under 1-star to the captain slot.</t>
    <t id="215">Sequentially consumes all available seminars in your inventory to train the captain's piloting skill to 5-star.</t>
    <t id="216">Sequentially consumes basic to 3-star seminars to train piloting skill up to 4-star.</t>
    <t id="217">Sequentially consumes basic to 2-star seminars to train piloting skill up to 3-star.</t>
    <t id="218">Consumes 1 seminar appropriate for the captain's current skill to promote the piloting skill by 1 tier.</t>
    <t id="219">Sequentially consumes basic to 1-star seminars to train piloting skill up to 2-star.</t>
    <t id="220">Sequentially consumes basic seminars to train piloting skill up to 1-star.</t>
    <t id="221">Consumes basic to 4-star seminars sequentially to train piloting skill to 5-star.</t>
    <!-- Category F: Unassigned Pilot Statistics Tooltips (ID: 250 ~ 269) -->
    <t id="250">Total unassigned pilots: %1</t>
    <t id="251">5-star pilots: %1</t>
    <t id="252">4-star and higher pilots: %1</t>
    <t id="253">3-star and higher pilots: %1</t>
    <t id="254">2-star and higher pilots: %1</t>
    <t id="255">1-star and higher pilots: %1</t>
    <t id="256">Under 5-star pilots: %1</t>
    <t id="257">Under 4-star pilots: %1</t>
    <t id="258">Under 3-star pilots: %1</t>
    <t id="259">Under 2-star pilots: %1</t>
    <t id="260">Under 1-star pilots: %1</t>
    <!-- Category G: Action Logbook & Notification Messages (ID: 300 ~ 399) -->
    <t id="300">Dismissed %1 captain[s].</t>
    <t id="301">Assigned captains to %1 ship[s].</t>
    <t id="302">Fired %1 captain[s].</t>
    <t id="303">Dismissed %2-star captain [%3] of ship %1.</t>
    <t id="304">Fired %2-star captain [%3] of ship %1.</t>
    <t id="305">Assigned %2-star captain [%3] to ship %1.</t>
    <t id="306">Transferred %2 unassigned crew to %1.</t>
    <t id="307">Seminar training complete: Promoted %1 captains. [Consumed: basic x%2, 1-star x%3, 2-star x%4, 3-star x%5, 4-star x%6]</t>
    <t id="308">Ejected all cargo [%2 types of wares] of ship %1 into space.</t>
    <!-- Category H: Disabled Warning Tooltips (ID: 400 ~ 499) -->
    <t id="400">No captain to dismiss.</t>
    <t id="401">A captain is already assigned to this ship.</t>
    <t id="402">The ship's crew quarters are full. To make room for the dismissed captain, the lowest-skilled crew member will be automatically fired.</t>
    <t id="403">Some ships have full crew quarters. To make room for the dismissed captains, the lowest-skilled crew member on those ships will be automatically fired.</t>
    <t id="404">No captain to fire.</t>
    <t id="405">No captain to train.</t>
    <t id="406">No cargo to drop.</t>
