    <t id="255">1星及以上飛行員數 : %1</t>
    <t id="256">5星以下飛行員數 : %1</t>
    <t id="257">4星以下飛行員數 : %1</t>
    <t id="258">3星以下飛行員數 : %1</t>
    <t id="259">2星以下飛行員數 : %1</t>
    <t id="260">1星以下飛行員數 : %1</t>
    <!-- Category G: Action Logbook & Notification Messages (ID: 300 ~ 399) -->
    <t id="300">已撤銷 %1 名艦長的職務。</t>
    <t id="301">已為 %1 艘飛船分配了艦長。</t>
